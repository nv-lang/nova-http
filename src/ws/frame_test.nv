// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-http: ws/frame_test.nv — RFC 6455 §5.7 worked examples (byte-exact
// fixtures straight from the spec text) + decode/encode round-trip +
// protocol-violation coverage. Peer test file (module tests beside module).

module http.ws

test "frame: unmasked single-frame text 'Hello' (RFC 6455 §5.7 ex.1)" {
    ro raw = Vec[u8].of(0x81, 0x05, 0x48, 0x65, 0x6c, 0x6c, 0x6f)
    ro (f, n) = Frame.decode(raw)!!
    assert(n == 7)
    assert(f.fin())
    assert(match f.opcode() { OpCode.Text => true, _ => false })
    assert(f.payload() == "Hello".bytes())
}

test "frame: masked single-frame text 'Hello' (RFC 6455 §5.7 ex.2)" {
    ro raw = Vec[u8].of(0x81, 0x85, 0x37, 0xfa, 0x21, 0x3d, 0x7f, 0x9f, 0x4d, 0x51, 0x58)
    ro (f, n) = Frame.decode(raw)!!
    assert(n == 11)
    assert(f.fin())
    assert(match f.opcode() { OpCode.Text => true, _ => false })
    assert(f.payload() == "Hello".bytes())
}

test "frame: fragmented unmasked text 'Hel'+'lo' (RFC 6455 §5.7 ex.3+4)" {
    ro raw1 = Vec[u8].of(0x01, 0x03, 0x48, 0x65, 0x6c)
    ro (f1, n1) = Frame.decode(raw1)!!
    assert(n1 == 5)
    assert(!f1.fin())
    assert(match f1.opcode() { OpCode.Text => true, _ => false })
    assert(f1.payload() == "Hel".bytes())

    ro raw2 = Vec[u8].of(0x80, 0x02, 0x6c, 0x6f)
    ro (f2, n2) = Frame.decode(raw2)!!
    assert(n2 == 4)
    assert(f2.fin())
    assert(match f2.opcode() { Continuation => true, _ => false })
    assert(f2.payload() == "lo".bytes())
}

test "frame: unmasked ping 'Hello' (RFC 6455 §5.7 ex.5)" {
    ro raw = Vec[u8].of(0x89, 0x05, 0x48, 0x65, 0x6c, 0x6c, 0x6f)
    ro (f, n) = Frame.decode(raw)!!
    assert(n == 7)
    assert(match f.opcode() { Ping => true, _ => false })
    assert(f.payload() == "Hello".bytes())
}

test "frame: masked pong 'Hello' (RFC 6455 §5.7 ex.6)" {
    ro raw = Vec[u8].of(0x8a, 0x85, 0x37, 0xfa, 0x21, 0x3d, 0x7f, 0x9f, 0x4d, 0x51, 0x58)
    ro (f, n) = Frame.decode(raw)!!
    assert(n == 11)
    assert(match f.opcode() { Pong => true, _ => false })
    assert(f.payload() == "Hello".bytes())
}

test "frame: 16-bit extended length (256-byte unmasked binary, RFC 6455 §5.7 ex.7)" {
    mut raw = Vec[u8].of(0x82, 0x7E, 0x01, 0x00)
    for _ in 0..256 { raw.push(0x44 as u8) }
    ro (f, n) = Frame.decode(raw)!!
    assert(n == 260)
    assert(match f.opcode() { Binary => true, _ => false })
    assert(f.payload().len() == 256)
}

test "frame: 64-bit extended length marker decodes size correctly" {
    // 130 encoded via the 8-byte length marker — decode must not require
    // "minimal" length encoding (RFC only recommends it for senders).
    mut raw = Vec[u8].of(0x82, 0x7F, 0, 0, 0, 0, 0, 0, 0, 130)
    for _ in 0..130 { raw.push(0x44 as u8) }
    ro (f, n) = Frame.decode(raw)!!
    assert(n == 10 + 130)
    assert(f.payload().len() == 130)
}

test "frame: reserved bit set -> ProtocolViolation" {
    ro raw = Vec[u8].of(0xC1, 0x00) // RSV1 set + FIN + opcode Text, empty payload
    ro r = Frame.decode(raw)
    assert(match r { Err(ProtocolViolation(_)) => true, _ => false })
}

test "frame: fragmented control frame -> ProtocolViolation" {
    ro raw = Vec[u8].of(0x09, 0x00) // FIN=0, opcode=Ping — control frame must not fragment
    ro r = Frame.decode(raw)
    assert(match r { Err(ProtocolViolation(_)) => true, _ => false })
}

test "frame: oversized control frame payload -> ProtocolViolation" {
    // FIN=1, Ping, len7=126 (extended 16-bit length) encoding 200 — the
    // control-frame size check fires right after the length is parsed,
    // before any payload bytes would even need to be present.
    ro raw = Vec[u8].of(0x89, 0x7E, 0x00, 0xC8)
    ro r = Frame.decode(raw)
    assert(match r { Err(ProtocolViolation(_)) => true, _ => false })
}

test "frame: truncated header -> BadFrame" {
    ro raw = Vec[u8].of(0x81)
    ro r = Frame.decode(raw)
    assert(match r { Err(BadFrame(_)) => true, _ => false })
}

test "frame: truncated payload -> BadFrame" {
    ro raw = Vec[u8].of(0x81, 0x05, 0x48, 0x65) // says len=5, only 2 bytes present
    ro r = Frame.decode(raw)
    assert(match r { Err(BadFrame(_)) => true, _ => false })
}

test "frame: encode unmasked round-trips through decode" {
    ro f = Frame.new(true, OpCode.Text, "round-trip".bytes())
    ro wire = f.encode(false)
    ro (f2, n) = Frame.decode(wire)!!
    assert(n == wire.len())
    assert(f2.payload() == "round-trip".bytes())
    assert(match f2.opcode() { OpCode.Text => true, _ => false })
}

test "frame: encode masked round-trips through decode (unmask restores payload)" {
    ro f = Frame.new(true, Binary, Vec[u8].of(1, 2, 3, 4, 5, 0, 255))
    ro wire = f.encode(true)
    ro (f2, n) = Frame.decode(wire)!!
    assert(n == wire.len())
    assert(f2.payload() == Vec[u8].of(1, 2, 3, 4, 5, 0, 255))
}

test "frame: frame_len_hint reports exact shortfall then None once complete" {
    ro raw = Vec[u8].of(0x81, 0x05, 0x48, 0x65, 0x6c, 0x6c, 0x6f)
    ro partial []u8 = raw[0..3]
    assert(frame_len_hint(partial) == Some(7 - 3))
    assert(frame_len_hint(raw).is_none())
}

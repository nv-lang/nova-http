// SPDX-License-Identifier: MIT OR Apache-2.0
// Plan 178 Ф.1 — Body must-consume (positive discharge) + Request/Response + HttpError.
//
// Migrated from nova_tests/http/body_test.nv (Plan 182 Ф.2, 2026-07-07) after the
// P67-LEGACY blocker was fixed: a `test{}` in `module std.http` used to crash the
// compiler with `[P67-LEGACY] Ident 'msg' not in var_types` — the executable-mode
// switch made a cross-module ErrorKind name-collision (std.http vs encoding.compress)
// reachable, and the name-keyed prelude-shadow type-skip
// (`should_skip_type`, emit_c.rs) dropped compress's ErrorKind sum-schema. Fixed by
// exempting `colliding_type_names` from the shadow-skip (both distinct types now emit).
module http

test "body: from_bytes/from_str discharge via bytes/text" {
    consume b1 = "hello".bytes().to_body()
    assert(b1.into_bytes()!!.len() == 5)
    consume b2 = "héllo".to_body_utf8()
    assert(b2.into_text()!! == "héllo")
}

test "body: stream reader drains in order" {
    mut chunks = Vec[[]u8].new()
    chunks.push("ab".bytes())
    chunks.push("cd".bytes())
    consume b = chunks.to_body_reader().into_body()
    assert(b.into_bytes()!!.len() == 4)
}

test "body: with_limit → BodyTooLarge" {
    consume b = "0123456789".bytes().to_body().with_limit(4)
    assert(match b.into_bytes() { Ok(_) => false, Err(e) => match e.kind { BodyTooLarge => true, _ => false } })
}

test "body: text rejects invalid UTF-8" {
    mut bad = Vec[u8].new()
    bad.push(0xFF as u8)
    bad.push(0xFE as u8)
    consume b = bad.to_body()
    assert(match b.into_text() { Ok(_) => false, Err(_) => true })
}

test "response: delegating discharge (must-consume body)" {
    ro h = HeaderMap.new()
    consume resp = Response.new(StatusCode.OK, h, "hi".bytes())
    assert(resp.is_success())
    assert(resp.status().code() == 200)
    assert(resp.into_text()!! == "hi")
}

test "request: build + drain" {
    ro u = "http://x/".to_url()!!
    ro h = HeaderMap.new()
    consume req = Request.new(Method.Post, u, h, "payload".bytes())
    assert(match req.method() { Post => true, _ => false })
    assert(req.into_body_bytes()!!.len() == 7)
}

test "httperror: kind + source-chain + to_str" {
    ro e = HttpError.protocol_error("bad line")
    assert(match e.kind { Protocol(m) => m == "bad line", _ => false })
    // InvalidUrl carries a ParseUrlError source (source-chaining)
    ro ue = match "nope".to_url() { Ok(_) => HttpError.protocol_error("x"), Err(e2) => e2 }
    assert(match ue.kind { InvalidUrl => true, _ => false })
    assert(ue.to_str().byte_len() > 0)
}

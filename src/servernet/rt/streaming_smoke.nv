// SPDX-License-Identifier: MIT OR Apache-2.0
// [M-178-server-streaming] (force-impl, Plan 116 worktree) — LIVE HTTP/1.1 SSE
// streaming over a loopback socket: proves `handle_connection`'s incremental
// chunk-by-chunk `write_all` path actually round-trips over `Net` (the pure/
// mock wire-format coverage lives in server/streaming_test.nv — this smoke is
// the socket-level proof that the same bytes actually arrive over a real
// connection, mirroring servernet/rt/handle_connection_smoke.nv).
//
// EXPECT_TIMEOUT_MS-marked (standalone per test-conventions.md — never folds
// into the shared http.servernet folder-CU).
//
// EXPECT_TIMEOUT_MS 30000

module rt.streaming_smoke

import std.net.{TcpListener, TcpStream, SocketAddr, real_net}
import ../../server.{Router, ServerResponse, StreamBody, handler_fn, sse_event}
import ../../serve.{handle_connection_router}

fn routes() -> Router {
    mut r = Router.new()
    r.get("/events", handler_fn(|req| {
        ro chunks [][]u8 = [sse_event("tick", "1"), sse_event("tick", "2"), sse_event("done", "bye")]
        ServerResponse.sse(StreamBody.from_chunks(chunks))
    }))!!
    r
}

test "servernet: live SSE streaming round-trip over loopback" {
    with Net = real_net() {
        consume lst = match TcpListener.bind(SocketAddr.loopback(0)) {
            Ok(consume l)  => l
            Err(_) => { assert(false); return }
        }
        ro port = lst.local_port()
        assert(port > 0)

        // Plan 173.3 (D415 §2): fiber results flow back through channels, not
        // outer-`mut` capture — see handle_connection_smoke.nv for the same
        // pattern this smoke mirrors.
        ro (ok_tx, ok_rx) = Channel.new(1)
        ro (got_tx, got_rx) = Channel.new(1)
        supervised {
            // Server fiber: accept one connection, stream the SSE response
            // through handle_connection's incremental writer.
            spawn {
                match lst.accept() {
                    Ok(consume srv) => {
                        consume s = srv
                        match handle_connection_router(s, routes()) {
                            Ok(_)  => { ok_tx.try_send(true) }
                            Err(_) => ()
                        }
                    }
                    Err(_) => ()
                }
            }
            // Client fiber: connect, send a raw GET, read the WHOLE streamed
            // response (loop until EOF — the server closes after the last
            // chunk, `Connection: close`, since no keep-alive is set).
            spawn {
                match TcpStream.connect(SocketAddr.loopback(port)) {
                    Ok(consume conn) => {
                        consume cli = conn
                        match cli.write_str("GET /events HTTP/1.1\r\nHost: localhost\r\n\r\n") {
                            Ok(_)  => ()
                            Err(_) => ()
                        }
                        mut acc []u8 = []u8.new()
                        mut reading = true
                        while reading {
                            match cli.read_to_vec(4096) {
                                Ok(chunk) => {
                                    if chunk.len() == 0 { reading = false } else { acc.append(chunk) }
                                }
                                Err(_) => { reading = false }
                            }
                        }
                        got_tx.try_send(acc)
                        cli.close()
                    }
                    Err(_) => ()
                }
            }
        }
        lst.close()
        ok_tx.close()
        got_tx.close()
        ro server_ok = ok_rx.try_recv() ?? false
        ro got = got_rx.try_recv() ?? []u8.new()
        assert(server_ok)
        ro resp = unsafe { got.to_str_unchecked() }
        assert(resp.contains("HTTP/1.1 200 OK"))
        assert(resp.contains("Transfer-Encoding: chunked")) // literal Title-Case, see server/streaming_test.nv
        assert(resp.contains("content-type: text/event-stream"))
        assert(resp.contains("event: tick\ndata: 1\n\n"))
        assert(resp.contains("event: tick\ndata: 2\n\n"))
        assert(resp.contains("event: done\ndata: bye\n\n"))
        assert(resp.ends_with("0\r\n\r\n"))
    }
}

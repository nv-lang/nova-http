// SPDX-License-Identifier: MIT OR Apache-2.0
// [M-178-server-policy-surface] (owner decision 2026-07-22; layer-contract
// refit 2026-07-23, Plan 222 §0а) — LIVE HTTP/1.1 smoke over loopback
// sockets for `serve_router()` (`../../serve/serve.nv`, the `Router`-taking
// convenience wrapper over `http.servernet.serve` + `ServerPolicy`
// (`../config.nv`)): keep-alive across multiple requests, request body-size
// cap → 413, chunked-request decode, header-deadline slowloris cutoff →
// 408, admission-control → 503. Pure/unit-level coverage of the byte-level
// policy helpers lives in `../policy_test.nv` instead (no sockets needed
// there — same-module private-fn access). Full design rationale (why each
// test binds its listener INSIDE the server's own `spawn`, why `with
// Fail[TimeoutError] = |_| {} { supervised(timeout: ...) { ... } }` bounds a
// test around `serve_router()`'s inherently infinite loop) was trimmed from
// this header — see git history (pre-2026-07-23) or `../policy_test.nv`'s
// own banner for the same pattern spelled out in full; kept short here so
// `EXPECT_TIMEOUT_MS` stays inside the test-runner's own first-30-lines scan
// window (`test_runner.rs` — a marker past line 30 is invisible to the
// timeout-lane gate, confirmed by hitting exactly this the first time this
// file's header grew past it).
//
// KNOWN STILL-OPEN compiler defect (task report has the isolated repro):
// [M-nv-cancel-loop-accept-swallowed] — a bare single `accept()` cancels
// fine under `supervised(timeout:)`, but `serve()`'s own accept LOOP (retry-
// on-Err) swallows the one-shot cancellation and never re-delivers it — so
// every test below (each bounding a live `serve_router()` loop) hangs until
// this lands upstream. Not a regression in this package (`nova check` stays
// clean); confirmed via a minimal repro with zero Router/ServerPolicy
// involved.
//
// EXPECT_TIMEOUT_MS 30000

module rt.serve_policy_smoke

import std.net.{TcpListener, TcpStream, SocketAddr, real_net}
import ../../server.{Router, ServerRequest, ServerResponse}
import ../../servernet.{ServerPolicy}
import ../../serve.{serve_router}

fn echo_routes() -> Router {
    mut r = Router.new()
    r.get("/health", fn(_req ServerRequest) -> ServerResponse => ServerResponse.text(200, "ok"))!!
    r.post("/echo", fn(req ServerRequest) -> ServerResponse {
        ro body = unsafe { req.body_bytes().to_str_unchecked() }
        ServerResponse.text(200, body)
    })!!
    r
}

// ── 1. keep-alive: two requests over ONE connection, honest close on the
//    client's own second `Connection: close` (deliverable 2) ─────────────

test "serve_router(): keep-alive — two requests over one connection, honest close on client header" {
    with Net = real_net() {
        ro (port_tx, port_rx) = Channel.new(1)
        ro (r1_tx, r1_rx) = Channel.new(1)
        ro (r2_tx, r2_rx) = Channel.new(1)
        with Fail[TimeoutError] = |_e| {} {
            supervised(timeout: 3.to_seconds()) {
                spawn {
                    consume lst = match TcpListener.bind(SocketAddr.loopback(0)) {
                        Ok(consume l)  => l
                        Err(_) => { ro _ = port_tx.try_send(0 as u16); return }
                    }
                    ro _ = port_tx.try_send(lst.local_port())
                    serve_router(lst, echo_routes(), ServerPolicy.new())
                }
                spawn {
                    ro port = match port_rx.recv() { Some(p) => p, None => 0 as u16 }
                    match TcpStream.connect(SocketAddr.loopback(port)) {
                        Ok(consume conn) => {
                            consume cli = conn
                            ro _ = cli.write_str("GET /health HTTP/1.1\r\nHost: localhost\r\n\r\n")
                            match cli.read_to_vec(4096) {
                                Ok(chunk) => { ro _ = r1_tx.try_send(chunk) }
                                Err(_)    => ()
                            }
                            ro _ = cli.write_str("GET /health HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n")
                            match cli.read_to_vec(4096) {
                                Ok(chunk) => { ro _ = r2_tx.try_send(chunk) }
                                Err(_)    => ()
                            }
                            cli.close()
                        }
                        Err(_) => ()
                    }
                }
            }
        }
        r1_tx.close()
        r2_tx.close()
        ro r1 = r1_rx.try_recv() ?? []u8.new()
        ro r2 = r2_rx.try_recv() ?? []u8.new()
        ro s1 = unsafe { r1.to_str_unchecked() }
        ro s2 = unsafe { r2.to_str_unchecked() }
        assert(s1.contains("HTTP/1.1 200 OK"))
        assert(s1.contains("ok"))
        assert(s1.contains("connection: keep-alive"))
        assert(s2.contains("HTTP/1.1 200 OK"))
        assert(s2.contains("connection: close"))
    }
}

// ── 2. body-size cap → 413 (deliverable 4) ─────────────────────────────────

test "serve_router(): declared Content-Length over the configured cap -> 413" {
    with Net = real_net() {
        ro (port_tx, port_rx) = Channel.new(1)
        ro (got_tx, got_rx) = Channel.new(1)
        with Fail[TimeoutError] = |_e| {} {
            supervised(timeout: 3.to_seconds()) {
                spawn {
                    consume lst = match TcpListener.bind(SocketAddr.loopback(0)) {
                        Ok(consume l)  => l
                        Err(_) => { ro _ = port_tx.try_send(0 as u16); return }
                    }
                    ro _ = port_tx.try_send(lst.local_port())
                    serve_router(lst, echo_routes(), ServerPolicy.new().max_body_bytes(8))
                }
                spawn {
                    ro port = match port_rx.recv() { Some(p) => p, None => 0 as u16 }
                    match TcpStream.connect(SocketAddr.loopback(port)) {
                        Ok(consume conn) => {
                            consume cli = conn
                            // Declared length (100) exceeds the 8-byte cap — the
                            // server must reject BEFORE attempting to read a body
                            // this small connect never actually sends.
                            ro _ = cli.write_str("POST /echo HTTP/1.1\r\nHost: localhost\r\nContent-Length: 100\r\n\r\n")
                            match cli.read_to_vec(4096) {
                                Ok(chunk) => { ro _ = got_tx.try_send(chunk) }
                                Err(_)    => ()
                            }
                            cli.close()
                        }
                        Err(_) => ()
                    }
                }
            }
        }
        got_tx.close()
        ro got = got_rx.try_recv() ?? []u8.new()
        ro s = unsafe { got.to_str_unchecked() }
        assert(s.contains("413"))
    }
}

// ── 3. chunked-request decode (deliverable 5) ─────────────────────────────

test "serve_router(): chunked request body decodes and reaches the handler" {
    with Net = real_net() {
        ro (port_tx, port_rx) = Channel.new(1)
        ro (got_tx, got_rx) = Channel.new(1)
        with Fail[TimeoutError] = |_e| {} {
            supervised(timeout: 3.to_seconds()) {
                spawn {
                    consume lst = match TcpListener.bind(SocketAddr.loopback(0)) {
                        Ok(consume l)  => l
                        Err(_) => { ro _ = port_tx.try_send(0 as u16); return }
                    }
                    ro _ = port_tx.try_send(lst.local_port())
                    serve_router(lst, echo_routes(), ServerPolicy.new())
                }
                spawn {
                    ro port = match port_rx.recv() { Some(p) => p, None => 0 as u16 }
                    match TcpStream.connect(SocketAddr.loopback(port)) {
                        Ok(consume conn) => {
                            consume cli = conn
                            ro _ = cli.write_str("POST /echo HTTP/1.1\r\nHost: localhost\r\nTransfer-Encoding: chunked\r\n\r\n5\r\nhello\r\n0\r\n\r\n")
                            match cli.read_to_vec(4096) {
                                Ok(chunk) => { ro _ = got_tx.try_send(chunk) }
                                Err(_)    => ()
                            }
                            cli.close()
                        }
                        Err(_) => ()
                    }
                }
            }
        }
        got_tx.close()
        ro got = got_rx.try_recv() ?? []u8.new()
        ro s = unsafe { got.to_str_unchecked() }
        assert(s.contains("HTTP/1.1 200 OK"))
        assert(s.contains("hello"))
    }
}

// ── 4. header-deadline slowloris cutoff → 408 (deliverable 3) ─────────────

test "serve_router(): incomplete headers past header_deadline -> 408" {
    with Net = real_net() {
        ro (port_tx, port_rx) = Channel.new(1)
        ro (got_tx, got_rx) = Channel.new(1)
        ro policy = ServerPolicy.new().header_deadline(150.to_millis()).idle_deadline(150.to_millis())
        with Fail[TimeoutError] = |_e| {} {
            supervised(timeout: 3.to_seconds()) {
                spawn {
                    consume lst = match TcpListener.bind(SocketAddr.loopback(0)) {
                        Ok(consume l)  => l
                        Err(_) => { ro _ = port_tx.try_send(0 as u16); return }
                    }
                    ro _ = port_tx.try_send(lst.local_port())
                    serve_router(lst, echo_routes(), policy)
                }
                spawn {
                    ro port = match port_rx.recv() { Some(p) => p, None => 0 as u16 }
                    match TcpStream.connect(SocketAddr.loopback(port)) {
                        Ok(consume conn) => {
                            consume cli = conn
                            // A partial request line with NO terminating blank
                            // line — the header block never completes.
                            ro _ = cli.write_str("GET /health HTTP/1.1\r\nHost: localhost\r\n")
                            (500).to_millis().sleep()
                            match cli.read_to_vec(4096) {
                                Ok(chunk) => { ro _ = got_tx.try_send(chunk) }
                                Err(_)    => ()
                            }
                            cli.close()
                        }
                        Err(_) => ()
                    }
                }
            }
        }
        got_tx.close()
        ro got = got_rx.try_recv() ?? []u8.new()
        ro s = unsafe { got.to_str_unchecked() }
        assert(s.contains("408"))
    }
}

// ── 5. admission control → 503 (deliverable 1) ────────────────────────────

test "serve_router(): over max_inflight -> 503, first connection still served" {
    with Net = real_net() {
        // Capacity 2 + sent TWICE below: BOTH client fibers (A and B) each
        // do their own `port_rx.recv()` — a capacity-1 channel would starve
        // the second receiver forever (each value is delivered to exactly
        // one receiver).
        ro (port_tx, port_rx) = Channel.new(2)
        ro (a_ready_tx, a_ready_rx) = Channel.new(1)
        ro (b_got_tx, b_got_rx) = Channel.new(1)
        ro policy = ServerPolicy.new().max_inflight(1).idle_deadline(5.to_seconds())
        with Fail[TimeoutError] = |_e| {} {
            supervised(timeout: 3.to_seconds()) {
                spawn {
                    consume lst = match TcpListener.bind(SocketAddr.loopback(0)) {
                        Ok(consume l)  => l
                        Err(_) => { ro _ = port_tx.try_send(0 as u16); ro _ = port_tx.try_send(0 as u16); return }
                    }
                    ro _ = port_tx.try_send(lst.local_port())
                    ro _ = port_tx.try_send(lst.local_port())
                    serve_router(lst, echo_routes(), policy)
                }
                // Client A: connect, hold the ONLY admission slot open long
                // enough for B to observe the reject, then disconnect.
                spawn {
                    ro port = match port_rx.recv() { Some(p) => p, None => 0 as u16 }
                    match TcpStream.connect(SocketAddr.loopback(port)) {
                        Ok(consume conn) => {
                            consume cli = conn
                            ro _ = a_ready_tx.try_send(true)
                            (600).to_millis().sleep()
                            cli.close()
                        }
                        Err(_) => { ro _ = a_ready_tx.try_send(false) }
                    }
                }
                // Client B: wait for A to be connected, then connect and
                // expect an immediate 503 (no route dispatch attempted).
                spawn {
                    ro a_ready = match a_ready_rx.recv() { Some(v) => v, None => false }
                    if a_ready {
                        (50).to_millis().sleep()   // let A's accept()/admission-count land first
                        ro port2 = match port_rx.recv() { Some(p) => p, None => 0 as u16 }
                        match TcpStream.connect(SocketAddr.loopback(port2)) {
                            Ok(consume conn) => {
                                consume cli = conn
                                match cli.read_to_vec(4096) {
                                    Ok(chunk) => { ro _ = b_got_tx.try_send(chunk) }
                                    Err(_)    => ()
                                }
                                cli.close()
                            }
                            Err(_) => ()
                        }
                    }
                }
            }
        }
        b_got_tx.close()
        ro got = b_got_rx.try_recv() ?? []u8.new()
        ro s = unsafe { got.to_str_unchecked() }
        assert(s.contains("503"))
    }
}

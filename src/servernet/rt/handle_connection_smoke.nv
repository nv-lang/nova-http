// SPDX-License-Identifier: MIT OR Apache-2.0
// Plan 182 Ф.2 (migrated from nova_tests/http_servernet/servernet_smoke_test.nv)
// — LIVE HTTP/1.1 server smoke over a loopback socket.
//
// Proves `http.servernet.handle_connection` end-to-end over a real socket:
// a server fiber accepts one connection and runs the request through the pure
// server core (ServeMux/serve_once); a client fiber connects, sends a raw GET,
// and reads back the serialized response. net + http co-present in ONE compile
// unit — this is also the [M-codegen-cross-module-ctor-emission] regression:
// `NetError.IoError(msg)` (net's uv-error classifier, reachable via the socket
// read/write paths) must emit its variant constructor, not the undefined
// `Nova_NetError_static_IoError` static form — otherwise the link fails.
//
// (Result[_, NetError] is destructured via `match`, not `!!`: `!!`
// throws through `Nova_Fail_fail`, whose typed-error path is a pre-existing net
// codegen gap unrelated to this smoke.)
//
// EXPECT_TIMEOUT_MS-marked (standalone per test-conventions.md — never folds
// into the shared http.servernet folder-CU).
//
// EXPECT_TIMEOUT_MS 30000

module rt.handle_connection_smoke

import std.net.{TcpListener, TcpStream, SocketAddr, real_net}
import ../../server.{Router, ServerResponse, handler_fn}
import ../../servernet.{handle_connection}

fn routes() -> Router {
    mut r = Router.new()
    r.get("/health", handler_fn(|req| ServerResponse.text(200, "ok")))!!
    r.fallback(handler_fn(|req| ServerResponse.text(404, "nope")))
    r
}

test "servernet: live GET /health round-trip over loopback" {
    with Net = real_net() {
        consume lst = match TcpListener.bind(SocketAddr.loopback(0)) {
            Ok(consume l)  => l
            Err(_) => { assert(false); return }
        }
        ro port = lst.local_port()
        assert(port > 0)

        // Plan 173.3 (D415 §2): fiber results flow back through channels, not
        // outer-`mut` capture (`mut got`/`mut server_ok` written from spawn →
        // E_CONCURRENT_MUT_CAPTURE). Each channel has exactly one producer.
        ro (ok_tx, ok_rx) = Channel.new(1)
        ro (got_tx, got_rx) = Channel.new(1)
        supervised {
            // Server fiber: accept one connection, serve it through handle_connection.
            spawn {
                match lst.accept() {
                    Ok(consume srv) => {
                        consume s = srv
                        match handle_connection(s, routes()) {
                            Ok(_)  => { ok_tx.try_send(true) }
                            Err(_) => ()
                        }
                    }
                    Err(_) => ()
                }
            }
            // Client fiber: connect, send a raw GET, read the response.
            spawn {
                match TcpStream.connect(SocketAddr.loopback(port)) {
                    Ok(consume conn) => {
                        consume cli = conn
                        match cli.write_str("GET /health HTTP/1.1\r\nHost: localhost\r\n\r\n") {
                            Ok(_)  => ()
                            Err(_) => ()
                        }
                        match cli.read_to_vec(4096) {
                            Ok(chunk) => { got_tx.try_send(chunk) }
                            Err(_)    => ()
                        }
                        cli.close()
                    }
                    Err(_) => ()
                }
            }
        }
        lst.close()
        ok_tx.close()
        got_tx.close()
        ro server_ok = ok_rx.try_recv() ?? false
        ro got = got_rx.try_recv() ?? []u8.new()
        assert(server_ok)
        ro resp = unsafe { got.to_str_unchecked() }
        assert(resp.contains("HTTP/1.1 200 OK"))
        assert(resp.contains("ok"))
    }
}

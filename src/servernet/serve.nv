// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-http: serve.nv — the reusable library accept-loop + persistent
// (keep-alive) per-connection driver `[M-178-server-policy-surface]`
// (owner decision 2026-07-22: закрыть сейчас).
//
// This is the "serve(listener, handler)" the file-header of `servernet.nv`
// itself flagged as missing (the flagship aggregator's own `main.nv` hand-
// rolls its accept loop today for exactly that reason — see that file's
// own `[M-187-nested-spawn-scope-var-cc-fail]`/
// `[M-187-high-concurrency-connection-wedge]` notes, which this module
// reuses the PROVEN shapes from: one `spawn` owns bind + the whole accept
// loop, `detach consume stream { ... }` per accepted connection, a
// `Semaphore` admission gate). `handle_connection` (`servernet.nv`,
// single-shot `Connection: close`) is UNCHANGED — this is a new, additive
// entry point; existing callers (the flagship aggregator, this package's
// own `rt/*_smoke.nv` tests) keep working exactly as before.
//
// Deliverable 1 (accept-loop hardening): `serve()`'s own `Err(_) => { ...
// back off; keep looping ... }` arm is the direct fix for the documented bug
// (`main.nv`'s current `Err(_) => { running = false }` — a transient accept
// error kills the WHOLE server). Admission control is the same shape as the
// aggregator's own mitigation (`[M-187-high-concurrency-connection-wedge]`)
// generalized into this package as a policy KNOB (`ServerPolicy.
// max_inflight`/`reject_with_503`) instead of a hardcoded app-level constant.
//
// ADMISSION GATE = `Semaphore.try_acquire_permit() -> Option[Permit]` (owner
// decision 2026-07-23, migrated same-day once the primitive landed —
// `std/runtime/sync.nv`'s own doc-comment names "connection pool capacity"
// as `Semaphore`'s canonical use case). WHY NOT a bare `AtomicInt` counter:
// a handler panic unwinds the connection-handling fiber via `longjmp` — a
// bare `ro _ = inflight.fetch_sub(1)` statement placed AFTER the panicking
// call is simply never reached (longjmp jumps PAST it, no unwind-time hook
// fires for an ordinary sequential statement) — the admission slot leaks
// forever. `Some(consume p) => { consume p { ... } }` fixes this properly:
// `p` (the `Permit`) lives in the CONNECTION's own scope and its `@cleanup`
// fires on scope-exit — success, error, OR panic (D432) — releasing the
// slot every time, no `defer`/bare-`release()` pairing needed at all
// (superseding this file's EARLIER `defer sem.release()`-based attempt,
// which itself had to route around a SEPARATE codegen defect — see
// `release_after`'s own git-history note, now removed along with it).
// `try_acquire_permit()` itself is non-blocking (`None` immediately on
// exhaustion, per its own doc-comment "designed for admission control:
// take slot or reject immediately") — exactly the non-parking semantics
// admission needs; no `try_acquire() -> bool` + manual `release()` pairing
// anymore.
//
// LAYER CONTRACT (Plan 222 §0а, refit 2026-07-23): same as `servernet.nv`'s
// own note — `serve`/`serve_connection` take a byte-level callback
// (`fn([]u8) -> ServerResponse`), NOT a `Router` — this module never imports
// `Router`/`route_once` (layer 2). `server/server_serve.nv`'s `serve_router`
// is the `Router`-taking convenience wrapper.

module http.servernet

import std.net.{TcpListener, TcpStream, NetError}
import std.runtime.sync.{Semaphore}
import std.time.duration
import ../server.{ServerResponse, serialize_response}
import ../server.{serialize_response_head, encode_chunk, encode_chunk_end}

// ── ws-hijack + recover-500: run one request's handler UNDER Stop-
//    supervision, INSIDE the write (Plan 222 final-plumbing tasks 1+2,
//    `[M-ws-on_upgrade-hijack-not-wired]` + `[M-servemux-recover-500]`) ────
//
// Composition, no new runtime primitive for the recover-500 half: SAME
// Stop-supervision shape as `BackgroundTasks.@drain()` (server/background.nv,
// D416) — a `supervised { spawn { ... } }` scope with a custom `Supervisor`
// handler whose `on_child_fail` returns `Decision.Stop` (the failure is
// contained, does NOT propagate, does NOT crash the process).
//
// WHY THE HANDLER CALL + UPGRADE CHECK + WIRE WRITE ALL HAPPEN **INSIDE**
// THE SPAWN (not: run the handler in a spawn, bring the `ServerResponse`
// back out, THEN decide/write) — found empirically while wiring this:
// `ServerResponse` embeds THREE closure-bearing `Option[...]` fields
// (`stream: Option[StreamBody]`, `background: Option[BackgroundTasks]`,
// `upgrade: Option[fn(TcpStream) Net -> ()]`) — the M:N share-ness checker
// cannot prove ANY of them safe to alias across a spawned-fiber boundary via
// a captured `mut` outer variable (`[E_CONCURRENT_MUT_CAPTURE] ...
// ServerResponse is poisoned at ServerResponse.stream::Some.0 (T): an
// unresolved type name T` — reproduces identically whether captured as
// `Option[ServerResponse]` or bare `ServerResponse`; a `Channel[ServerResponse]`
// fails EARLIER still, at codegen — `E_CHANNEL_UNSOUND_ELEM_TYPE`,
// `ServerResponse`'s C struct isn't pointer-sized, `Channel[T]`'s runtime
// backing is a single `nova_int`-sized slot, `nova_rt/channels.h`). A
// payload-less enum (`ConnStep` below) WITH an explicit type annotation on
// the captured local DOES cross the boundary safely (probed in isolation:
// `mut step ConnStep = ConnStep.StepX` inside a nested `supervised { spawn
// consume shs = s.share() { step = ... } }` — no annotation → a SEPARATE
// `E_CONCURRENT_MUT_CAPTURE` variant, "type is unknown at the capture site",
// since the checker's syntactic type-sketch pass doesn't recognize a bare
// enum-variant constructor `Step.A` as a `Named{Type}` ctor pattern the way
// it does `Type.new(...)`/literals — WITH the annotation, both variants
// disappear). So: `resp` is produced and consumed by the SAME fiber (never
// crosses out), and only the outcome DISCRIMINATOR crosses back — same
// `s.share()` cross-fiber-lend recipe `policy.nv`'s own `read_attempt`
// already proves for a plain read. Both gaps: report to integrator for
// `docs/plans/backlog-followups.md` (this worktree does not touch the nova
// repo).
//
// D437 caveat (owner-requested normative anchor, spec/decisions/08-runtime.md):
// the runtime's own uncaught-panic diagnostic is "message + throw-site +
// propagation trace" — but that full format is ONLY ever printed by the
// runtime's own top-level unhandled-abort path
// (`nova_throw_site_dump`/`effects.h`); there is NO Nova-level accessor that
// exposes the throw-site/trace to a `Supervisor.on_child_fail` handler (`err
// any` only yields the message via `.try_as[str]()`, confirmed against
// `effects.h`/`fibers.h`'s own C source — `nova_throw_site_set`/
// `_nova_throw_site` are C-internal, no extern binding anywhere in `std/`).
// `BackgroundTasks.@drain()` hits the exact same wall and logs message-only
// — this fn does the same, honestly, rather than fabricate a "site".
type ConnStep enum
    | StepKeepAlive // wrote OK, both sides agreed to continue the connection
    | StepClose     // wrote OK (or nothing to write), connection ends here
    | StepCloseErr  // a write failed — connection ends here, propagate NetError

// Read+dispatch already happened (`read_one_request`, caller) — this runs
// `handler(raw)` UNDER Stop-supervision, checks the result for a ws-hijack
// (`@take_upgrade()`), and writes the response, ALL inside the same spawned
// fiber (see banner above for why). On a caught panic/throw, logs
// `"handler panic: <message>"` via `policy`'s own sink
// (`policy.panic_emit`/`@panic_sink`) and answers per `policy.panic_response()`:
// `InternalError500` -> writes a 500 (in THIS, the un-panicked caller fiber —
// the spawn already exited), `Close` -> writes nothing.
fn run_request(s mut TcpStream, handler fn([]u8) -> ServerResponse, raw []u8, policy ServerPolicy, keep_alive bool) Net Time -> ConnStep {
    // `failed`/`reason` captured by `on_child_fail` below — legal (checked:
    // `nova check src --strict-effects` is clean, no E_CONCURRENT_MUT_CAPTURE
    // for either), and NOT a coincidence of the type being `bool`/`str`: the
    // M:N mut-capture race-checker only fires for `spawn`/`parallel for`/
    // `detach` BODIES (its own error text says so verbatim); `on_child_fail`
    // is a `Supervisor` EFFECT-HANDLER closure, not one of those three — per
    // D416 §2 (spec/decisions/06-concurrency.md, normative): "on_child_fail
    // исполняется на drive-потоке scope'а (drain-цикл
    // nova_supervised_run_impl), по одному падению за раз" — it runs
    // SERIALLY on the SAME drive thread/fiber that owns the `supervised{}`
    // scope, never migrates, never runs concurrently with anything —
    // structurally outside the race-checker's scope, same reason
    // `BackgroundTasks.@drain()` (server/background.nv, ALREADY shipped)
    // captures the identical `mut failed`/`mut reason` shape with no
    // workaround needed.
    mut failed = false
    mut reason = ""
    mut step ConnStep = ConnStep.StepCloseErr
    with Supervisor = effect Supervisor {
        on_child_fail(idx, err) -> Decision {
            failed = true
            if let Some(msg) = err.try_as[str]() {
                reason = msg
            } else {
                reason = "non-string handler error"
            }
            return Decision.Stop
        }
    } {
        supervised {
            spawn consume shs = s.share() {
                mut resp = handler(raw)
                match resp.take_upgrade() {
                    // ws-hijack (task 1): write the 101 bytes, then hand the
                    // LIVE (shared) socket to the hook instead of the normal
                    // keep-alive continuation/close. `hook(shs)` moves `shs`
                    // for good (`TcpStream` has its own `@cleanup`, D188 — no
                    // double-close risk; `s`, the ORIGINAL, is untouched here
                    // and still gets its own `@close()` from the caller's
                    // trailing cleanup — rc-aware, so that is a harmless
                    // decrement, not a real double-close, per `TcpStream.
                    // @share()`'s own doc-comment). `supervised { spawn { ... }
                    // }` (not `detach`) BLOCKS until `hook` returns — exactly
                    // right: `run_request`/`serve_connection` legitimately
                    // don't have anything else to do with this connection
                    // until the whole WebSocket session ends (fiber-per-
                    // connection model, same as every other blocking `Net`
                    // call already in this driver).
                    Some(hook) => {
                        resp.header("Connection", "Upgrade")
                        match write_response_keepalive(shs, resp) {
                            Ok(_)  => { hook(shs); step = ConnStep.StepClose }
                            Err(_) => { step = ConnStep.StepCloseErr }
                        }
                    }
                    None => {
                        resp.header("Connection", if keep_alive { "keep-alive" } else { "close" })
                        match write_response_keepalive(shs, resp) {
                            Ok(_)  => { step = if keep_alive { ConnStep.StepKeepAlive } else { ConnStep.StepClose } }
                            Err(_) => { step = ConnStep.StepCloseErr }
                        }
                    }
                }
            }
        }
    }
    if failed {
        (policy.panic_emit)("handler panic: ${reason}")
        match policy.panic_response() {
            // `InternalError500`: the panic was cleanly caught BEFORE any
            // response bytes went out (the whole handler call + write
            // happens inside the SAME Stop-supervised spawn above, so a
            // panic mid-handler never left a partial/corrupted response on
            // the wire) — a well-formed `500` is exactly as safe to keep the
            // connection alive after as any other response, so this honors
            // the SAME `keep_alive` decision (`read_one_request`/
            // `should_keep_alive`, policy.nv) every other response does: the
            // server stays up AND, if both sides agreed to keep-alive, this
            // SAME connection goes on to serve the next request (recover-500
            // task 2's own acceptance shape — "connection stays alive for
            // the NEXT request", not just "a NEW connection can still be
            // admitted").
            HandlerPanicResponse.InternalError500 => {
                mut resp500 = ServerResponse.text(500, "500 internal server error")
                resp500.header("Connection", if keep_alive { "keep-alive" } else { "close" })
                ro _ = write_response_keepalive(s, resp500)
                if keep_alive { ConnStep.StepKeepAlive } else { ConnStep.StepClose }
            }
            HandlerPanicResponse.Close => ConnStep.StepClose
        }
    } else {
        step
    }
}

// ── Non-consuming response write (keep-alive: the stream survives to serve
//    the NEXT request on success) — mirrors `handle_connection`'s own
//    fixed/streaming split (`write_streaming`/`write_stream_chunks`), but
//    those two take `consume` and unconditionally `@close()` the stream
//    (correct for the single-shot handler, wrong here). ────────────────────

fn write_response_keepalive(s mut TcpStream, resp ServerResponse) Net -> Result[(), NetError] {
    if resp.is_streaming() {
        write_streaming_keepalive(s, resp)
    } else {
        s.write_all(serialize_response(resp))
    }
}

fn write_streaming_keepalive(s mut TcpStream, resp ServerResponse) Net -> Result[(), NetError] {
    match s.write_all(serialize_response_head(resp)) {
        Ok(_)  => write_stream_chunks_keepalive(s, resp)
        Err(e) => Err(e)
    }
}

fn write_stream_chunks_keepalive(s mut TcpStream, resp ServerResponse) Net -> Result[(), NetError] {
    match resp.take_stream() {
        None => Ok(())   // unreachable: caller checked @is_streaming()
        Some(sb) => {
            mut producer = sb
            mut running = true
            mut result Result[(), NetError] = Ok(())
            while running {
                match producer.next_chunk() {
                    Some(chunk) => {
                        match s.write_all(encode_chunk(chunk)) {
                            Ok(_)  => ()
                            Err(e) => { result = Err(e); running = false }
                        }
                    }
                    None => {
                        match s.write_all(encode_chunk_end()) {
                            Ok(_)  => ()
                            Err(e) => { result = Err(e) }
                        }
                        running = false
                    }
                }
            }
            result
        }
    }
}

// ── serve_connection: persistent (keep-alive) per-connection driver ───────
//
// Replaces `handle_connection`'s single-shot "read one, respond, close"
// with a loop: read a GOVERNED request (`read_one_request`, `policy.nv` —
// deadlines/body-cap/chunked-decode already applied), dispatch it through
// `handler` (byte-level callback — see this file's own layer-contract note;
// `server/server_serve.nv`'s `serve_router` is the `Router`-taking
// convenience wrapper most callers actually want), force the wire
// `Connection` header to match the keep-alive decision (the pure-core
// serializer defaults to `close` whenever the response doesn't already set
// one — `server/wire.nv` `serialize_response`/`serialize_response_head` —
// so an explicit override here is what actually MAKES keep-alive happen on
// the wire, no server.nv change needed), write it, and loop again if both
// sides agreed to continue. `served_count` is the loop's own counter
// (starts at 0, passed to `read_one_request` so `should_keep_alive` can
// enforce `max_requests_per_conn`).
#stable(since = "0.1")
export fn serve_connection(consume stream TcpStream, handler fn([]u8) -> ServerResponse, policy ServerPolicy) Net Time -> Result[(), NetError] {
    consume s = stream
    mut served_count = 0
    mut keep_going = true
    mut final_result Result[(), NetError] = Ok(())
    while keep_going {
        match read_one_request(s, policy, served_count) {
            Ready(raw, keep_alive) => {
                served_count += 1
                // ws-hijack (task 1) + recover-500 (task 2): `run_request`
                // (above) runs `handler(raw)` under Stop-supervision, checks
                // `@take_upgrade()`, and writes the response — ALL inside its
                // own spawned fiber (see that fn's own banner for why the
                // response value never crosses back out here, only the
                // `ConnStep` discriminator does).
                match run_request(s, handler, raw, policy, keep_alive) {
                    StepKeepAlive => { keep_going = true }
                    StepClose     => { keep_going = false }
                    StepCloseErr  => { keep_going = false; final_result = Err(NetError.Closed) }
                }
            }
            EarlyResponse(resp0) => {
                mut resp = resp0
                resp.header("Connection", "close")
                ro _ = write_response_keepalive(s, resp)
                keep_going = false
            }
            ConnectionDone => {
                keep_going = false
            }
        }
    }
    s.close()
    final_result
}

// ── serve: the reusable library accept loop ────────────────────────────────
//
// Shape mirrors the flagship aggregator's own `main()` accept loop (proven
// against two documented codegen/runtime failure modes — see this file's
// own header): exactly ONE `spawn` holds bind + the whole loop; each
// accepted connection is handed to `detach consume stream { ... }`
// (bounded-concurrent, not sequential); a `Semaphore.try_acquire_permit()`
// (see this file's own header — panic-safe via the returned `Permit`'s own
// `@cleanup`, NOT a bare counter) is the admission gate. Two hardening
// fixes over that hand-rolled original (deliverable 1):
//   - `Err(_)` from `accept()` no longer kills the loop — it backs off
//     briefly and continues (a transient accept error, e.g. the OS FD table
//     momentarily full, should not take the whole server down);
//   - the admission-reject path now optionally answers with a real `503`
//     (`policy.reject_with_503()`) instead of always just closing — a
//     friendlier, retry-safe signal to a well-behaved client.
//
// The admission CHECK (`inflight.try_acquire_permit()`) runs INSIDE the
// `detach { }` body, not before it — `detach consume c { ... }` only names
// ONE explicit linear capture (D415 §4: "requires a block body — the
// orphan fiber owns `c`"; no multi-name form, confirmed empirically), and
// BOTH `stream` (`TcpStream consume`) and the `Permit` a successful
// admission produces are linear values that need to cross into the SAME
// orphan fiber. Obtaining the `Permit` fresh INSIDE the already-`detach`ed
// body (rather than in the outer accept loop, then somehow moving TWO
// linear values across the fiber boundary at once) sidesteps that
// single-capture limit entirely — `p` never crosses a fiber boundary, it is
// created and consumed by the SAME fiber throughout. Functionally
// equivalent to a pre-detach check (same accept/reject responses over the
// wire); the only difference is a rejected connection's own tiny `detach`
// still gets spawned before it rejects — negligible cost for a bool check
// + immediate close, not the "unbounded nested work" class of concern
// `[M-187-high-concurrency-connection-wedge]` was actually about.
#stable(since = "0.1")
export fn serve(consume listener TcpListener, handler fn([]u8) -> ServerResponse, policy ServerPolicy) Net Time Detach {
    consume lst = listener
    // [M-nv-spawn-ctx-capture-mut-param-ptr-mismatch]: CLOSED (ОКНО-1,
    // 2026-07-23, nova main f83d3d87f) — the residual variant this file
    // used to route around (capturing a bare VALUE-type PARAMETER into a
    // `detach { ... }` ctx after an earlier `ro`-receiver method call on it,
    // e.g. `policy.max_inflight()` below) is fixed; `policy`/`handler`
    // capture straight into `detach { }` with no local-rebind indirection
    // needed anymore (confirmed by this file's own `nova test` run — see
    // task report for the pass count).
    mut inflight = Semaphore.new(policy.max_inflight())
    mut running = true
    while running {
        match lst.accept() {
            Ok(consume stream) => {
                detach consume stream {
                    match inflight.try_acquire_permit() {
                        Some(consume p) => {
                            // `p` lives in THIS connection's own scope —
                            // `@cleanup` (D432) releases the slot on scope
                            // exit, success OR panic, no defer/bare-release
                            // pairing needed.
                            consume p {
                                ro _ = serve_connection(stream, handler, policy)
                            }
                        }
                        None => {
                            if policy.reject_with_503() {
                                ro _ = stream.write_all("HTTP/1.1 503 Service Unavailable\r\nConnection: close\r\nContent-Length: 0\r\n\r\n".bytes())
                            }
                            stream.close()
                        }
                    }
                }
            }
            Err(_) => {
                // Deliverable 1: transient accept error — back off briefly,
                // KEEP LOOPING (do not exit). Mirrors the fixed-interval
                // retry shape already proven in this codebase's own
                // reconnect/backoff call sites; no unbounded busy-loop.
                (20).to_millis().sleep()
            }
        }
    }
    lst.close()
}

// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-http: decompress_br_test.nv — in-module test for the transparent
// `Content-Encoding: br` decode branch (Plan 179 Ф.2 / [M-178-autodecompress-br];
// owner convention: tests live next to the module).
//
// The mock serves the OFFICIAL google/brotli vector 10x10y.compressed with
// `Content-Encoding: br`; the client must return the decoded plaintext with the
// encoding header stripped (same header-rewrite contract as gzip/deflate).
// brotli has no pure-Nova encoder, hence the fixed official vector (anti-circular
// by construction — the fixture bytes come from the reference implementation).

module http.client

import http.{Http}

// hex string → []u8 (file-scoped name; wire.nv's hex_digit has a different shape).
fn br_hexbytes(s str) -> []u8 {
    ro chars = s.bytes()
    mut out []u8 = []u8.new(cap: chars.len() / 2)
    mut i = 0
    while i + 1 < chars.len() {
        out.push(((br_hexval(chars[i]) << 4) | br_hexval(chars[i + 1])) as u8)
        i = i + 2
    }
    out
}

fn br_hexval(c u8) -> int {
    ro n = c as int
    if n >= 48 && n <= 57 { n - 48 }
    else if n >= 97 && n <= 102 { n - 97 + 10 }
    else { 0 }
}

test "decompress: brotli (br) body is transparently decoded" {
    // Official google/brotli vector 10x10y.compressed → "XXXXXXXXXXYYYYYYYYYY".
    ro comp = br_hexbytes("1b130000a4b0b2ea8147028a")
    ro m = mock_http().on("GET", "/b",
        MockResponse.new(200).header("Content-Encoding", "br").body(comp))
    with Http = effect Http { send(host, port, secure, request) { m.reply(request) } } {
        consume resp = HttpClient.new().get("http://x.example/b").send()!!
        // Content-Encoding stripped; body is the decoded plaintext.
        assert(match resp.header("content-encoding") { Some(_) => false, None => true })
        assert(resp.text()!! == "XXXXXXXXXXYYYYYYYYYY")
    }
}

// SPDX-License-Identifier: MIT OR Apache-2.0
// Plan 182 Ф.2 (migrated from nova_tests/http_decompress/decompress_test.nv) —
// transparent Content-Encoding decode (gzip/deflate) + bomb guard.
//
// Circular proof: the mock server encodes a body with `compress`
// (`gzip_encode`/`zlib_encode`) and serves it with `Content-Encoding: gzip`
// (resp. deflate); the client transparently decodes it back to the ORIGINAL
// bytes. Negative: a body that decodes past the client's `max_decompressed`
// cap (D334) fails with the typed `Err(BodyTooLarge)`, not an OOM.
// Deterministic via mock_http (no sockets); inline frame-capturing handler
// (GC-safe, see [M-178-mock-handler-gc-trace]). Complements decompress_br_test.nv
// (brotli) with gzip/deflate coverage.
//
// This is also the [M-178-autodecompress-needs-179] landing: compress + http
// `ErrorKind` co-present in ONE compile unit (unblocked by the D381 collision fix).

module http.client

import http.{Http}
import compress.{gzip_encode, zlib_encode, CompressLevel}

// gzip-encode a string body (panics only in test setup if encoding fails).
fn gz(s str) -> []u8 {
    match gzip_encode(s.bytes(), CompressLevel.default()) {
        Ok(b)  => b
        Err(_) => Vec[u8].new()
    }
}

fn zl(s str) -> []u8 {
    match zlib_encode(s.bytes(), CompressLevel.default()) {
        Ok(b)  => b
        Err(_) => Vec[u8].new()
    }
}

// ── gzip round-trip ────────────────────────────────────────────────────────────

test "decompress: gzip body is transparently decoded" {
    ro payload = "hello, gzip world — transparently decompressed!"
    ro m = mock_http().on("GET", "/g",
        MockResponse.new(200).header("Content-Encoding", "gzip").body(gz(payload)))
    with Http = effect Http { send(host, port, secure, request) -> Result[str, HttpError] { m.reply(request) } } {
        ro resp = HttpClient.new().get("http://x.example/g").send()!!
        assert(resp.into_text()!! == payload)
    }
}

// ── deflate (zlib) round-trip + header rewrite ─────────────────────────────────

test "decompress: deflate (zlib) body decoded, Content-Encoding dropped" {
    ro payload = "deflate/zlib payload body"
    ro m = mock_http().on("GET", "/d",
        MockResponse.new(200).header("Content-Encoding", "deflate").body(zl(payload)))
    with Http = effect Http { send(host, port, secure, request) -> Result[str, HttpError] { m.reply(request) } } {
        ro resp = HttpClient.new().get("http://x.example/d").send()!!
        // Header now describes the DECODED body (Content-Encoding stripped).
        assert(match resp.header("content-encoding") { Some(_) => false, None => true })
        assert(resp.into_text()!! == payload)
    }
}

// ── opt-out: no auto-decompress leaves the body compressed ─────────────────────

test "decompress: disabled → body stays gzip-compressed" {
    ro payload = "raw stays raw"
    ro compressed = gz(payload)
    ro m = mock_http().on("GET", "/r",
        MockResponse.new(200).header("Content-Encoding", "gzip").body(compressed))
    with Http = effect Http { send(host, port, secure, request) -> Result[str, HttpError] { m.reply(request) } } {
        mut b = HttpClient.builder()
        b.no_decompress()
        ro client = b.into_client()!!
        ro resp = client.get("http://x.example/r").send()!!
        // Body is returned verbatim (still gzip), Content-Encoding preserved.
        assert(match resp.header("content-encoding") { Some(e) => e == "gzip", None => false })
        assert(resp.into_bytes()!!.len() == compressed.len())
    }
}

// ── negative: decompression bomb → typed BodyTooLarge ──────────────────────────

test "decompress: gzip bomb past max_decompressed → Err(BodyTooLarge)" {
    // 20 000 repeated bytes compress tiny but decode large; cap at 256.
    consume big = StringBuilder.new()
    big.cap(20000)
    mut i = 0
    while i < 20000 { big.append("A"); i += 1 }
    ro payload = big.into_str()
    ro m = mock_http().on("GET", "/bomb",
        MockResponse.new(200).header("Content-Encoding", "gzip").body(gz(payload)))
    with Http = effect Http { send(host, port, secure, request) -> Result[str, HttpError] { m.reply(request) } } {
        mut b = HttpClient.builder()
        b.max_decompressed(256)
        ro client = b.into_client()!!
        ro res = client.get("http://x.example/bomb").send()
        assert(match res {
            Ok(resp) => { ro _ = resp.drain(); false }
            Err(e)   => match e.kind { BodyTooLarge => true, _ => false }
        })
    }
}

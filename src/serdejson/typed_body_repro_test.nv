// SPDX-License-Identifier: MIT OR Apache-2.0
// [M-178-server-typed-body] minimal repro: typed request-body decode
// (`json_decode_body[T]`) used from a `ServeMux` handler — i.e. `http.server`
// AND `http.serdejson` (which itself transitively needs `http.client` for
// `Response`) combined in ONE CU. Lives HERE (serdejson's own folder, not
// `std/http/server/`) deliberately: dropping a serde-`#impl` type + a
// `json_decode_body[T]` call into `std/http/server/` would pull serde into
// `http.server`'s OWN module surface, breaking every OTHER unrelated
// importer of `http.server` that doesn't want a serde dependency (e.g.
// `http.servernet` — verified: adding this test under
// `std/http/server/` made `nova test std/http/servernet` fail with
// `E_EXTENSION_METHOD_NEEDS_IMPORT` on `HashMap.serialize()`). Same
// leanness rationale as the serdejson.nv module banner itself.

module http.serdejson

import ../server.{Router, ServerResponse, serve_once}
import std.encoding.serde.{Serialize, Deserialize, Serializer, Deserializer, SerError, DeError}

#impl(Serialize + Deserialize)
type ReqWidget value {
    ro id   int
    ro name str
}

test "typed request body: json_decode_body[T] decodes ServerRequest.body_bytes() in the server CU" {
    ro req = "POST /w HTTP/1.1\r\nHost: x\r\nContent-Length: 24\r\n\r\n{\"id\":7,\"name\":\"gizmo\"}".bytes()
    mut got_id = 0
    mut got_name = ""
    mut router = Router.new()
    router.post("/w", fn(r ServerRequest) -> ServerResponse {
        match json_decode_body[ReqWidget](r.body_bytes()) {
            Ok(w) => {
                got_id = w.id
                got_name = w.name
                ServerResponse.text(200, "ok")
            }
            Err(_) => ServerResponse.text(400, "bad")
        }
    })!!
    ro wire []u8 = serve_once(router, req)
    ro s = unsafe { wire.to_str_unchecked() }
    assert(s.contains("200"))
    assert(got_id == 7)
    assert(got_name == "gizmo")
}

// SPDX-License-Identifier: MIT OR Apache-2.0
// Plan 182 Ф.2 (migrated from nova_tests/http_typed/typed_json_test.nv) —
// typed JSON decode `json_decode_body[T]()` over serde. Deterministic via
// mock_http (no sockets). [M-178-typed-json-needs-180]

module http.serdejson

import ../client.{HttpClient, mock_http, MockResponse}
import http.{Http}
import std.encoding.serde.{Serialize, Deserialize, Serializer, Deserializer, SerError, DeError}

#impl(Serialize + Deserialize)
type Widget value {
    ro id    int
    ro name  str
    ro tags  []str
    ro ratio f64
    ro note  Option[str]
}

// ── typed round-trip: JSON body → record DTO ─────────────────────────────────

test "typed json: record DTO decodes from response body" {
    ro wire_body = "{\"id\":7,\"name\":\"gizmo\",\"tags\":[\"a\",\"b\"],\"ratio\":1.5,\"note\":\"hi\"}"
    ro m = mock_http().on("GET", "/w", MockResponse.new(200)
        .header("Content-Type", "application/json")
        .text(wire_body))
    with Http = effect Http { send(host, port, secure, request) -> Result[str, HttpError] { m.reply(request) } } {
        ro resp = HttpClient.new().get("http://x.example/w").send()!!
        ro w = json_decode_body[Widget](resp.into_bytes()!!)!!
        assert(w.id == 7)
        assert(w.name == "gizmo")
        assert(w.tags.len() == 2)
        assert(w.tags[0] == "a")
        assert(w.ratio == 1.5)
        assert(w.note == Some("hi"))
    }
}

// ── typed round-trip: absent/null optional field → None ──────────────────────

test "typed json: optional field null decodes to None" {
    ro wire_body = "{\"id\":1,\"name\":\"x\",\"tags\":[],\"ratio\":0.0,\"note\":null}"
    ro m = mock_http().on("GET", "/w2", MockResponse.new(200).text(wire_body))
    with Http = effect Http { send(host, port, secure, request) -> Result[str, HttpError] { m.reply(request) } } {
        ro resp = HttpClient.new().get("http://x.example/w2").send()!!
        ro w = json_decode_body[Widget](resp.into_bytes()!!)!!
        assert(w.note == None)
        assert(w.tags.len() == 0)
    }
}

// ── neg: malformed JSON → Err(Protocol) with serde detail ────────────────────

test "typed json: malformed body → Err(Protocol)" {
    ro m = mock_http().on("GET", "/bad", MockResponse.new(200).text("{not json"))
    with Http = effect Http { send(host, port, secure, request) -> Result[str, HttpError] { m.reply(request) } } {
        ro resp = HttpClient.new().get("http://x.example/bad").send()!!
        match json_decode_body[Widget](resp.into_bytes()!!) {
            Ok(_)  => assert(false)
            Err(e) => assert(match e.kind { Protocol(_) => true, _ => false })
        }
    }
}

// ── neg: missing required field → Err(Protocol) ──────────────────────────────

test "typed json: missing required field → Err(Protocol)" {
    ro m = mock_http().on("GET", "/miss", MockResponse.new(200)
        .text("{\"id\":3,\"tags\":[],\"ratio\":2.0}"))     // no "name"
    with Http = effect Http { send(host, port, secure, request) -> Result[str, HttpError] { m.reply(request) } } {
        ro resp = HttpClient.new().get("http://x.example/miss").send()!!
        match json_decode_body[Widget](resp.into_bytes()!!) {
            Ok(_)  => assert(false)
            Err(e) => assert(match e.kind { Protocol(_) => true, _ => false })
        }
    }
}

// ── method form: `resp.into_json_as[T]()` (turbofish in return position) ───────────
// [M-codegen-method-return-turbofish] — the generic-method form now monomorphizes
// correctly (T appears only in the return type; the method-call turbofish carries it).

test "typed json: method form resp.into_json_as[T]() decodes the body" {
    ro wire_body = "{\"id\":9,\"name\":\"widget\",\"tags\":[\"x\",\"y\",\"z\"],\"ratio\":2.5,\"note\":\"hey\"}"
    ro m = mock_http().on("GET", "/wm", MockResponse.new(200)
        .header("Content-Type", "application/json")
        .text(wire_body))
    with Http = effect Http { send(host, port, secure, request) -> Result[str, HttpError] { m.reply(request) } } {
        ro resp = HttpClient.new().get("http://x.example/wm").send()!!
        ro w = resp.into_json_as[Widget]()!!
        assert(w.id == 9)
        assert(w.name == "widget")
        assert(w.tags.len() == 3)
        assert(w.tags[2] == "z")
        assert(w.ratio == 2.5)
        assert(w.note == Some("hey"))
    }
}

test "typed json: method form malformed body → Err(Protocol)" {
    ro m = mock_http().on("GET", "/badm", MockResponse.new(200).text("{oops"))
    with Http = effect Http { send(host, port, secure, request) -> Result[str, HttpError] { m.reply(request) } } {
        ro resp = HttpClient.new().get("http://x.example/badm").send()!!
        match resp.into_json_as[Widget]() {
            Ok(_)  => assert(false)
            Err(e) => assert(match e.kind { Protocol(_) => true, _ => false })
        }
    }
}

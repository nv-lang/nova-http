// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-http: wire.nv — HTTP/1.1 server-side wire codec (D361). Extracted
// from monorepo std/http (Plan 203 Ф.1).
//
// Parse a raw request (request-line + headers + Content-Length body) into a
// `ServerRequest`, and serialize a `ServerResponse` to wire bytes. Pure Nova over
// `[]u8` (byte-correct incl. non-UTF-8 bodies). CORE request framing: Content-
// Length (identity); chunked REQUEST decode is deferred (server.nv markers).
// Streaming RESPONSE bodies (`Transfer-Encoding: chunked`) are DONE — see
// `serialize_response_head`/`encode_chunk`/`encode_chunk_end` below
// (`[M-178-server-streaming]`). Header name/value validation (CR/LF/NUL, tchar)
// is enforced by HeaderMap/HeaderValue (anti-injection, shared with the client).

module http.server

import http.{Method, StatusCode, Version, HeaderMap, HttpError}

// ── Request parsing ────────────────────────────────────────────────────────────

// Parse a full raw HTTP/1.1 request. Malformed request-line/headers → Protocol.
// `Host` is mandatory (HTTP/1.1, RFC 9112 §3.2) → missing Host is a Protocol error.
fn parse_request(raw []u8) -> Result[ServerRequest, HttpError] {
    ro n = raw.len()
    ro head_end = match find_double_crlf(raw, 0) {
        Some(x) => x
        None    => return Err(HttpError.protocol_error("request: no header terminator"))
    }
    ro body_start = head_end + 4

    ro first_eol = match find_crlf(raw, 0) {
        Some(x) => x
        None    => return Err(HttpError.protocol_error("request: empty request line"))
    }
    ro (method, target, path, query, version) = parse_request_line(raw[0..first_eol])?

    mut hm = HeaderMap.new()
    mut i = first_eol + 2
    mut running = true
    while running && i < head_end {
        ro eol = match find_crlf(raw, i) { Some(x) => x, None => head_end }
        if eol <= i {
            running = false
        } else {
            parse_header_line(hm, raw[i..eol])?
            i = eol + 2
        }
    }

    if !hm.contains("host") {
        return Err(HttpError.protocol_error("request: missing mandatory Host header"))
    }

    // Body framing: Content-Length (identity). Absent → empty body (CORE).
    ro body = match hm.content_length()? {
        Some(len) => {
            ro avail = n - body_start
            ro take = len.min(avail)
            raw[body_start..body_start + take]
        }
        None => []u8.new()
    }

    // [](str, str).new() в expression-позиции не парсится — типизированный локал.
    ro params [](str, str) = []
    Ok({ method, target, path, query, version, headers: hm, params, body })
}

fn parse_request_line(line []u8) -> Result[(Method, str, str, str, Version), HttpError] {
    ro sp1 = match index_of(line, 0x20, 0) {
        Some(x) => x
        None    => return Err(HttpError.protocol_error("request line: no space after method"))
    }
    // [M-174.1-vec-method-chain-elem-erasure]: explicit `[]u8` locals — a
    // facade-imported method (`to_str_unchecked`) chained directly on a
    // fn-call result loses the concrete element type (backlog-followups.md).
    ro method_bytes []u8 = line[0..sp1]
    ro method = Method.parse(unsafe { method_bytes.to_str_unchecked() })?
    ro sp2 = match index_of(line, 0x20, sp1 + 1) {
        Some(x) => x
        None    => return Err(HttpError.protocol_error("request line: no space after target"))
    }
    ro target_bytes []u8 = line[sp1 + 1..sp2]
    ro target = unsafe { target_bytes.to_str_unchecked() }
    if target.byte_len() == 0 {
        return Err(HttpError.protocol_error("request line: empty target"))
    }
    // Reject `..`-traversal in the raw target (path smuggling defence, Q14/Q28).
    if target.contains("..") {
        return Err(HttpError.protocol_error("request line: path traversal (..) rejected"))
    }
    ro ver_bytes []u8 = line[sp2 + 1..line.len()]
    ro version = parse_version(unsafe { ver_bytes.to_str_unchecked() })?
    ro (path, query) = match target.find("?") {
        Some(q) => (target[0..q], target[q + 1..target.byte_len()])
        None    => (target, "")
    }
    Ok((method, target, path, query, version))
}

fn parse_version(tok str) -> Result[Version, HttpError] {
    match tok {
        "HTTP/1.0" => Ok(Http10)
        "HTTP/1.1" => Ok(Http11)
        _          => Err(HttpError.protocol_error("request line: unsupported HTTP version"))
    }
}

fn parse_header_line(hm mut HeaderMap, line []u8) -> Result[(), HttpError] {
    ro colon = match index_of(line, 0x3A, 0) {
        Some(x) => x
        None    => return Err(HttpError.protocol_error("header line: no colon"))
    }
    // [M-174.1-vec-method-chain-elem-erasure]: explicit `[]u8` local.
    ro name_bytes []u8 = line[0..colon]
    ro name = unsafe { name_bytes.to_str_unchecked() }
    ro value = trim_ows(line[colon + 1..line.len()])
    hm.append_bytes(name, value)?
    Ok(())
}

// ── Response serialization ─────────────────────────────────────────────────────

/// Serialize a ServerResponse to wire bytes. Adds Content-Length + Connection:close
/// when absent. HEAD/204/304 body suppression is applied by the caller (driver).
/// Fixed-body path only — streaming responses (`@is_streaming()`) go through
/// `serialize_response_head` + `encode_chunk`/`encode_chunk_end` instead (see
/// `drain_stream_to_bytes` below / servernet.nv's live incremental writer).
/// Exported (`[M-178-server-streaming]`) so `http.servernet.handle_connection`
/// can reuse the SAME fixed-body serializer for the non-streaming path instead of
/// duplicating it — net isolation keeps `Net`/`TcpStream` out of this module (see
/// servernet.nv banner).
#stable(since = "0.1")
export fn serialize_response(resp ServerResponse) -> []u8 {
    ro { status, headers, body, .. } = resp
    mut buf = WriteBuffer.new()
    buf.cap(128 + body.len())
    buf.write_str("HTTP/1.1 ")
    buf.write_str(status.to_str())
    buf.write_str(" ")
    buf.write_str(reason_of(status))
    buf.write_str("\r\n")

    for (nm, v) in headers {
        buf.write_str(nm.str())
        buf.write_str(": ")
        buf.write_bytes(v.bytes())
        buf.write_str("\r\n")
    }

    if !headers.contains("content-length") && !headers.contains("transfer-encoding") {
        buf.write_str("Content-Length: ")
        buf.write_str(body.len().to_str())
        buf.write_str("\r\n")
    }
    if !headers.contains("connection") {
        buf.write_str("Connection: close\r\n")
    }
    buf.write_str("\r\n")
    if body.len() > 0 {
        buf.write_bytes(body)
    }
    buf.into_bytes()
}

// ── Streaming response wire format (`[M-178-server-streaming]`) ───────────────
//
// RFC 9112 §7.1 chunked transfer-coding, write side. Pairs with the DECODER
// already landed on the client (`decode_chunked`, http.client.wire) — same
// wire format, opposite direction.

/// Serialize a streaming response's status-line + headers ONLY (no body — the
/// body is written separately, chunk by chunk, by the caller). Forces
/// `Transfer-Encoding: chunked` (RFC 9112 §7.1) and omits `Content-Length`
/// (length unknown ahead of time for a pulled stream). Exported for
/// `http.servernet`'s live incremental socket writer — net isolation keeps
/// `Net`/`TcpStream` out of this module (see servernet.nv banner);
/// `encode_chunk`/`encode_chunk_end` frame each subsequent chunk.
#stable(since = "0.1")
export fn serialize_response_head(resp ServerResponse) -> []u8 {
    ro { status, headers, .. } = resp
    mut buf = WriteBuffer.new()
    buf.cap(160)
    buf.write_str("HTTP/1.1 ")
    buf.write_str(status.to_str())
    buf.write_str(" ")
    buf.write_str(reason_of(status))
    buf.write_str("\r\n")

    for (nm, v) in headers {
        buf.write_str(nm.str())
        buf.write_str(": ")
        buf.write_bytes(v.bytes())
        buf.write_str("\r\n")
    }

    if !headers.contains("transfer-encoding") {
        buf.write_str("Transfer-Encoding: chunked\r\n")
    }
    if !headers.contains("connection") {
        buf.write_str("Connection: close\r\n")
    }
    buf.write_str("\r\n")
    buf.into_bytes()
}

/// Frame one chunk per RFC 9112 §7.1: `<hex-size>\r\n<data>\r\n`.
#stable(since = "0.1")
export fn encode_chunk(data []u8) -> []u8 {
    mut buf = WriteBuffer.new()
    buf.cap(data.len() + 16)
    buf.write_str(to_hex_lower(data.len()))
    buf.write_str("\r\n")
    if data.len() > 0 { buf.write_bytes(data) }
    buf.write_str("\r\n")
    buf.into_bytes()
}

/// Terminating zero-length chunk + empty trailer section (RFC 9112 §7.1.2):
/// `0\r\n\r\n`.
#stable(since = "0.1")
export fn encode_chunk_end() -> []u8 => "0\r\n\r\n".bytes()

// Fully drain a streaming response's producer into ONE byte buffer (head +
// every chunk + terminator) — the pure/mock-test path (`serve_once`). The live
// socket runner (servernet.nv `handle_connection`) does NOT use this: it writes
// each chunk to the socket as it is pulled, for TRUE incremental delivery.
fn drain_stream_to_bytes(resp ServerResponse) -> []u8 {
    mut buf = WriteBuffer.new()
    buf.write_bytes(serialize_response_head(resp))
    match resp.take_stream() {
        Some(sb) => {
            mut producer = sb
            mut running = true
            while running {
                match producer.next_chunk() {
                    Some(chunk) => buf.write_bytes(encode_chunk(chunk))
                    None        => { buf.write_bytes(encode_chunk_end()); running = false }
                }
            }
        }
        None => ()
    }
    buf.into_bytes()
}

// Lowercase-hex render of a non-negative int (chunk size). "0" for zero.
fn to_hex_lower(n int) -> str {
    if n == 0 { return "0" }
    mut digits []u8 = []u8.new()
    mut v = n
    while v > 0 {
        digits.push(hex_char_lower(v % 16))
        v = v / 16
    }
    // `digits` accumulated least-significant-first — reverse for MSB-first text.
    mut out []u8 = []u8.new(cap: digits.len())
    mut i = digits.len() - 1
    while i >= 0 {
        out.push(digits[i])
        i -= 1
    }
    unsafe { out.to_str_unchecked() }
}

fn hex_char_lower(d int) -> u8 {
    if d < 10 { (0x30 + d) as u8 } else { (0x61 + d - 10) as u8 }
}

fn reason_of(status int) -> str {
    match StatusCode.new(status as u16) {
        Ok(sc) => {
            ro r = sc.reason()
            if r.byte_len() > 0 { r } else { "Status" }
        }
        Err(_) => "Status"
    }
}

// ── byte helpers ────────────────────────────────────────────────────────────────

fn index_of(b []u8, target int, from int) -> Option[int] {
    ro n = b.len()
    mut i = from
    while i < n {
        if (b[i] as int) == target { return Some(i) }
        i += 1
    }
    None
}

fn find_crlf(b []u8, from int) -> Option[int] {
    ro n = b.len()
    mut i = from
    while i + 1 < n {
        if (b[i] as int) == 0x0D && (b[i + 1] as int) == 0x0A { return Some(i) }
        i += 1
    }
    None
}

fn find_double_crlf(b []u8, from int) -> Option[int] {
    ro n = b.len()
    mut i = from
    while i + 3 < n {
        if (b[i] as int) == 0x0D && (b[i + 1] as int) == 0x0A &&
           (b[i + 2] as int) == 0x0D && (b[i + 3] as int) == 0x0A {
            return Some(i)
        }
        i += 1
    }
    None
}

fn trim_ows(b []u8) -> []u8 {
    ro n = b.len()
    mut lo = 0
    while lo < n && is_ows(b[lo] as int) { lo += 1 }
    mut hi = n
    while hi > lo && is_ows(b[hi - 1] as int) { hi -= 1 }
    b[lo..hi]
}

fn is_ows(c int) -> bool => c == 0x20 || c == 0x09

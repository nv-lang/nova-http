// SPDX-License-Identifier: MIT OR Apache-2.0
// Plan 182 Ф.2 (migrated from nova_tests/http_server/server_test.nv) —
// HTTP/1.1 server CORE, mock-driven (no sockets): parse → route → serialize
// via `serve_once`. Exercises ServeMux params/method/405-Allow, 404, POST
// body echo, Host-mandatory + `..`-reject. [M-178-std-http] server core.

module http.server

// Build a small router used across the cases.
// [M-184-mut-chain-return-position] (http-хвост, 2026-07-07): беглая цепочка
// mut-сеттеров КАК return-значение fn (`ServeMux.new().get(..)...` глубины 4)
// после 184 Ф.2 всё ещё мискомпилируется — C-инициализация
// `NovaValue_ServeMux` из `NovaValue_ServeMux*` (fleeting `-> @` отдаёт
// указатель, return-позиция ждёт значение). Statement-/arg-позиции depth 2-3
// покрыты p184_defect_b; return-позиция — нет. Канонический mut-биндинг ниже.
fn routes() -> ServeMux {
    mut mux = ServeMux.new()
    mux.get("/health", handler_fn(|req| ServerResponse.text(200, "ok")))
    mux.get("/users/{id}", handler_fn(|req| {
        ServerResponse.text(200, "user " + req.param("id") ?? "?")
    }))
    mux.post("/echo", handler_fn(|req| {
        ServerResponse.bytes(200, "application/octet-stream", req.body_bytes())
    }))
    mux.not_found(handler_fn(|req| ServerResponse.text(404, "nope")))
    mux
}

// Assert the response wire begins with a given status line and contains a substring.
fn resp_contains(wire []u8, needle str) -> bool =>
    unsafe { wire.to_str_unchecked() }.contains(needle)

fn status_line(wire []u8) -> str {
    ro s = unsafe { wire.to_str_unchecked() }
    match s.find("\r\n") { Some(i) => s[0..i], None => s }
}

// ── GET routing + literal path ────────────────────────────────────────────────

test "server: GET /health → 200 ok" {
    ro req = "GET /health HTTP/1.1\r\nHost: x\r\n\r\n".bytes()
    ro wire = serve_once(routes(), req)
    assert(status_line(wire) == "HTTP/1.1 200 OK")
    assert(resp_contains(wire, "ok"))
}

// ── path parameter extraction ──────────────────────────────────────────────────

test "server: GET /users/{id} extracts param" {
    ro req = "GET /users/42 HTTP/1.1\r\nHost: x\r\n\r\n".bytes()
    ro wire = serve_once(routes(), req)
    assert(status_line(wire) == "HTTP/1.1 200 OK")
    assert(resp_contains(wire, "user 42"))
}

// ── POST body echo (Content-Length framing) ────────────────────────────────────

test "server: POST /echo returns the request body" {
    ro req = "POST /echo HTTP/1.1\r\nHost: x\r\nContent-Length: 5\r\n\r\nhello".bytes()
    ro wire = serve_once(routes(), req)
    assert(status_line(wire) == "HTTP/1.1 200 OK")
    assert(resp_contains(wire, "hello"))
    assert(resp_contains(wire, "Content-Length: 5"))
}

// ── 404: no route matches ──────────────────────────────────────────────────────

test "server: unknown path → 404 not_found handler" {
    ro req = "GET /missing HTTP/1.1\r\nHost: x\r\n\r\n".bytes()
    ro wire = serve_once(routes(), req)
    assert(status_line(wire) == "HTTP/1.1 404 Not Found")
    assert(resp_contains(wire, "nope"))
}

// ── 405: path matches, method does not (+ Allow) ───────────────────────────────

test "server: wrong method → 405 + Allow" {
    ro req = "DELETE /health HTTP/1.1\r\nHost: x\r\n\r\n".bytes()
    ro wire = serve_once(routes(), req)
    assert(status_line(wire) == "HTTP/1.1 405 Method Not Allowed")
    assert(resp_contains(wire, "allow: GET"))     // header names serialize lowercased (canonical)
}

// ── HEAD falls back to a GET route ─────────────────────────────────────────────

test "server: HEAD routes to GET handler" {
    ro req = "HEAD /health HTTP/1.1\r\nHost: x\r\n\r\n".bytes()
    ro wire = serve_once(routes(), req)
    assert(status_line(wire) == "HTTP/1.1 200 OK")
}

// ── neg: missing mandatory Host → 400 ──────────────────────────────────────────

test "server: missing Host → 400" {
    ro req = "GET /health HTTP/1.1\r\n\r\n".bytes()
    ro wire = serve_once(routes(), req)
    assert(status_line(wire) == "HTTP/1.1 400 Bad Request")
}

// ── neg: path traversal (..) rejected → 400 ────────────────────────────────────

test "server: path traversal (..) → 400" {
    ro req = "GET /users/../secret HTTP/1.1\r\nHost: x\r\n\r\n".bytes()
    ro wire = serve_once(routes(), req)
    assert(status_line(wire) == "HTTP/1.1 400 Bad Request")
}

// ── neg: malformed request line → 400 ──────────────────────────────────────────

test "server: garbage request → 400" {
    ro req = "not a request\r\n\r\n".bytes()
    ro wire = serve_once(routes(), req)
    assert(status_line(wire) == "HTTP/1.1 400 Bad Request")
}

// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-http: server.nv ‚Äî HTTP/1.1 server CORE (pure Nova, D361). Extracted
// from monorepo std/http (Plan 203 –§.1).
//
// The version-logic of the server ‚Äî request parsing, `ServerRequest`/`ServerResponse`
// model, `Handler`, `ServeMux` path-routing (Go-1.22-style {param} + method + 405
// Allow), response serialization, and the `serve_once` driver ‚Äî is PURE Nova (no Net
// effect), so it is exhaustively mock-testable WITHOUT sockets (D361 mock-first).
// The live accept-loop over real sockets is a thin runner in http.servernet
// (over the `Net` effect + supervised/spawn/CancelToken ‚Äî Plan 173/83.x substrate),
// which reuses `serve_once` verbatim.
//
// CORE scope (plaintext HTTP/1.1): in-memory request body (buffered by the conn
// driver), Content-Length framing, `Handler` returns a value `ServerResponse`.
// Handler is a newtype over the fn type (`type Handler fn(ServerRequest) ->
// ServerResponse`, D52/D55 –û–ö–ù–û-5 2026-07-23): a bare fn/closure auto-lifts
// into it at any Handler-expecting position, and a Handler VALUE is called
// directly (`h(req)`) ‚Äî Go `http.HandlerFunc` shape. The former `handler_fn`
// constructor and `@handle` method were removed with the newtype-over-fn
// migration (222.3 ¬ß5–∞, owner decision 2026-07-23).
//
// Streaming RESPONSE bodies (`[M-178-server-streaming]`, Plan 178 followup) ‚Äî
// DONE (Plan 116/M-178-server-streaming force-impl): `StreamBody`/`stream_body`
// (pull-source chunk producer) + `ServerResponse.stream`/`.sse` construct a
// `Transfer-Encoding: chunked` response; `serialize_response_head`/`encode_chunk`/
// `encode_chunk_end` (wire.nv) frame the wire bytes (RFC 9112 ¬ß7.1);
// `http.servernet.handle_connection` drives the LIVE incremental socket write
// (chunk-by-chunk `write_all`) ‚Äî write-backpressure comes for free from the
// EXISTING `Net.write` park-on-full-buffer behaviour (std/net/tcp.nv
// `@write_all`), no new runtime primitive needed. `serve_once` (pure, mock-
// testable) fully drains the producer instead, so the wire FORMAT is covered
// without sockets ‚Äî see server_test.nv. Streaming REQUEST bodies + chunked
// REQUEST decode remain deferred, unrelated to this –§.1/187 SSE gate:
//   ¬∑ middleware onion, 100-continue, keep-alive, chunked request decode
//     [M-178-server-policy-surface]
//   ¬∑ graceful deadline-drain ‚Äî `supervised(deadline:)`/`supervised(timeout:)`
//     landed (Plan 174, D408, 2026-07-06) and is now hardened (Plan 173 –§.3,
//     2026-07-12/13: fixed a real leak where a spawned child parked on
//     `Time.sleep` did not actually unwind on scope-deadline cancellation ‚Äî
//     see `std/concurrency/supervised_deadline_test.nv` test 8, `fibers.h`
//     `_nova_sleep_via_libuv`/`_nova_sleep_via_driver`). The primitive is no
//     longer the blocker; `servernet.nv` has no accept-LOOP function yet at
//     all (only single-shot `handle_connection` + smoke tests) ‚Äî wiring a
//     bounded deadline-drain into a real multi-connection accept loop is
//     std/http-side work, tracked separately. [M-178-server-graceful-deadline]
//
// Typed `#impl(Deserialize)` request bodies (`[M-178-server-typed-body]`) ‚Äî DONE:
// the reported "serde in the http CU trips a codegen defect" was TWO real
// compiler bugs, both fixed at the root (not worked around):
//   (1) types/mod.rs chain-receiver mut check: `recv_returning` (fluent `-> @`
//       registry) was NAME-only, not arity-scoped, so an unrelated same-name
//       `-> @` method on a DIFFERENT type/arity (`ServeMux mut @post(pattern,
//       handler) -> @`, arity 2) falsely poisoned an unrelated call
//       (`HttpClient.post(url).body(b)`, arity 1) ‚Üí spurious
//       E_RECEIVER_BINDING_NOT_MUT. Fixed with an arity-aware companion
//       registry (`recv_returning_arity`), mirroring the existing
//       `mut_methods_arity`/`ro_methods_arity` precedent.
//   (2) emit_c.rs free-fn symbol mangling/registration (three call sites ‚Äî
//       `fn_module_map`/`file_priv_fn_c_names`, the D84 `method_overloads`
//       registration pass, and the D29 shadow-skip `should_skip_fn`) assumed
//       a bare free-fn name is unique across the whole CU; a module-private
//       (default, no `export`) free fn of the same name in TWO different
//       modules (`http.client`'s private `serialize_response(status,
//       headers, body) -> str` vs `http.server`'s exported
//       `serialize_response(resp) -> []u8`) ‚Äî genuinely unrelated functions,
//       not overloads ‚Äî collided into one C symbol / got silently dropped.
//       Fixed by widening the existing cross-module collision detection
//       (previously identical-signature-only) to also catch this
//       different-signature-but-not-all-exported case, and threading that
//       detection through all three sites.
// Minimal repro: `std/http/serdejson/typed_body_repro_test.nv` (decodes a
// `json_decode_body[T]` POST body inside a `ServeMux` handler ‚Äî exercises
// BOTH bugs at once, since it needs `http.server` + `http.client`
// (transitively, via `http.serdejson`) in the same CU). Lives in
// serdejson's own folder, NOT here, so `http.server`'s own module surface
// stays serde-free for OTHER importers (see that file's banner).

module http.server

import http.{Method, StatusCode, Version, HeaderMap, HttpError}
import std.net.{TcpStream}

// ‚îÄ‚îÄ ServerRequest ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

/// A fully-received HTTP/1.1 request (CORE: body buffered in memory). Path params
/// (`{name}` from the matched `ServeMux` route) are filled in by dispatch.
#stable(since = "0.1")
export type ServerRequest value {
    ro method  Method
    ro target  str              // raw request-target (origin-form: path[?query])
    ro path    str              // decoded path (query stripped)
    ro query   str              // raw query string ("" if none)
    ro version Version
    ro headers HeaderMap
    params     [](str, str)     // matched {name} path params (mut: set by ServeMux.@dispatch via @params(ps))
    ro body    []u8
    // Multipart-parsing guardrails snapshot (`[M-222.11-multipart-limits-not-
    // wired-to-serverpolicy]`, Plan 222 final-plumbing task 3): `MultipartLimits`
    // lives in THIS module (multipart.nv, folder-peer sorting BEFORE server.nv ‚Äî
    // D78 sorted-peer order), so embedding it here needs no cross-module import.
    // `http.server` cannot import `http.servernet`'s `ServerPolicy` directly
    // (would make the two modules mutually dependent ‚Äî see servernet.nv's own
    // layer-contract banner for the confirmed A‚áÑB cycle symptom), so the
    // policy ‚Üí parser channel goes the OTHER way: `http.serve` (the one module
    // allowed to import BOTH) reads `policy.multipart_limits()` and threads it
    // down through `route_once_with_multipart_limits`/`router_callback_with_limits`
    // (`server.nv`/`server_serve.nv`, both below) into THIS field, which
    // `Multipart.from_request` (multipart.nv) then reads instead of a hardcoded
    // `MultipartLimits.new()`. Defaults to `MultipartLimits.new()` wherever a
    // request is built without going through that threading (`parse_request`,
    // `wire.nv`) ‚Äî every existing caller (`serve_once`, mock tests,
    // `router_callback`/`handle_connection_router`'s single-shot path) keeps
    // today's fixed defaults unchanged.
    multipart_limits MultipartLimits // plain (no `ro`) ‚Äî `@multipart_limits(v) -> @` reassigns it directly, same shape as `params` above
}

/// Independent copy (D230/D246 canon (b)). Field-shorthand shallow copy is
/// sufficient here ‚Äî `params`/`headers`/`body` are never mutated IN PLACE
/// by any consumer of a clone (`Router.@dispatch`, server_router.nv, is the
/// one caller: it only ever REASSIGNS the whole `params` field to a fresh
/// `Vec` via the `@params(v)` setter, never appends into the shared one),
/// so no per-field `.clone()` is needed to avoid aliasing.
/// Canon (a) (`mut` PARAMETER) was tried FIRST for `@dispatch` and REJECTED:
/// it hits a live codegen gap ‚Äî calling a method with an ordinary
/// (non-receiver) `mut`-typed struct argument omits the required
/// address-of at the CALL site (`Nova_Router_method_dispatch(&(router),
/// req)` compiles with `req` passed by value while the callee's own second
/// param is `NovaValue_ServerRequest*`), CC-FAIL "passing
/// NovaValue_ServerRequest to parameter of incompatible type
/// NovaValue_ServerRequest *; take the address with &" ‚Äî reproduced via
/// `nova test src` (whole-package CU); only the RECEIVER slot (1st arg)
/// reliably gets `&` at method-call sites.
/// `[M-mut-nonreceiver-struct-param-method-call-missing-addressof]`
fn ServerRequest @clone() -> ServerRequest =>
    { @method, @target, @path, @query, @version, @headers, @params, @body, @multipart_limits }

/// Request method.
#stable(since = "0.1")
export fn ServerRequest @method() -> Method => @method
/// Decoded request path (no query).
#stable(since = "0.1")
export fn ServerRequest @path() -> str => @path
/// Raw request-target (path + optional "?query").
#stable(since = "0.1")
export fn ServerRequest @target() -> str => @target
/// Request headers.
#stable(since = "0.1")
export fn ServerRequest @headers() -> HeaderMap => @headers
/// Buffered request body bytes.
#stable(since = "0.1")
export fn ServerRequest @body_bytes() -> []u8 => @body

/// First value of a request header (case-insensitive), or `None`.
#stable(since = "0.1")
export fn ServerRequest @header(name str) -> Option[str] {
    match @headers.get(name) {
        Some(hv) => match hv.to_str() { Ok(s) => Some(s), Err(_) => None }
        None     => None
    }
}

/// A matched path parameter (`{name}`), or `None`.
#stable(since = "0.1")
export fn ServerRequest @param(name str) -> Option[str] {
    for (k, v) in @params {
        if k == name { return Some(v) }
    }
    None
}

/// First query parameter value for `key` (percent-decoded), or `None`.
#stable(since = "0.1")
export fn ServerRequest @query_param(key str) -> Option[str] {
    for (k, v) in parse_query(@query) {
        if k == key { return Some(v) }
    }
    None
}

/// Attach matched path params (used by ServeMux dispatch). Mutating fleeting
/// property (D117 AMEND-2): a copying `with_params` would shallow-copy the
/// heap-backed `headers`/`body` fields, sharing them with the pre-dispatch
/// request ‚Äî no real independence, just an extra allocation.
#stable(since = "0.1")
export fn ServerRequest mut @params(ps [](str, str)) -> @ {
    @params = ps
}

/// The multipart-parsing limits snapshot in effect for this request (see the
/// field's own doc-comment above) ‚Äî read by `Multipart.from_request`
/// (multipart.nv). Defaults to `MultipartLimits.new()` unless threaded
/// through `route_once_with_multipart_limits`/`ServerPolicy`.
#stable(since = "0.1")
export fn ServerRequest @multipart_limits() -> MultipartLimits => @multipart_limits

/// Attach a multipart-limits snapshot (used by
/// `route_once_with_multipart_limits` below ‚Äî not part of the normal
/// request-parsing path, `parse_request` already fills in the default).
#stable(since = "0.1")
export fn ServerRequest mut @multipart_limits(v MultipartLimits) -> @ {
    @multipart_limits = v
}

// `StreamBody` (streamed response body chunk-producer, `[M-178-server-streaming]`)
// is declared here, ahead of `ServerResponse`, because `ServerResponse` embeds it
// BY VALUE via `Option[StreamBody]` ‚Äî a value-typed field must be a complete type
// at its embedding site (C struct layout needs `sizeof`), so the producer type
// itself has to precede the struct that holds it; the ergonomic constructors
// (`stream_body`, `.from_chunks`, `@next_chunk`) stay below in the "Streamed
// response body" section next to `ServerResponse.stream`/`.sse`, since ordinary
// function declaration order is unconstrained (only embedded-value STRUCT layout
// is order-sensitive).
#stable(since = "0.1")
export type StreamBody value { priv f fn() -> Option[[]u8] }

// ‚îÄ‚îÄ ServerResponse ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

/// A handler's response (CORE: in-memory body ‚Üí exact Content-Length framing;
/// `stream` set ‚Üí chunked/streaming body, see `ServerResponse.stream`/`.sse`
/// below, `[M-178-server-streaming]`; `background` set ‚Üí FastAPI-`BackgroundTasks`-
/// style deferred work, run by the connection driver AFTER the response bytes
/// are on the wire ‚Äî see `background.nv`'s `BackgroundTasks`, Plan 222.16).
#stable(since = "0.1")
export type ServerResponse value {
    ro status     int
    ro headers    HeaderMap
    body          []u8
    ro stream     Option[StreamBody]
    background    Option[BackgroundTasks]
    // ws-hijack hook (`[M-ws-on_upgrade-hijack-not-wired]`, Plan 222
    // final-plumbing task 1): set by `WebSocketUpgrade.@on_upgrade`
    // (ws_upgrade.nv, SAME module) ‚Äî raw `TcpStream`, NOT `WebSocket`, so this
    // core "wire model" file stays decoupled from `http.ws` (the WebSocket
    // protocol layer imports DOWN into `http.server`'s types today ‚Äî
    // `ws_upgrade.nv` ‚Äî not the other way around). `http.servernet.serve_connection`
    // (serve.nv) checks `@take_upgrade()` AFTER writing this response's bytes
    // (the 101 handshake) and, if set, hands the live socket to the hook
    // INSTEAD OF the normal keep-alive continuation/close ‚Äî same
    // `Option[...]`-hook shape as `background` above (`@take_background`).
    upgrade       Option[fn(TcpStream) Net -> ()]
}

/// Response with a status code and empty body/headers.
#stable(since = "0.1")
export fn ServerResponse.new(status int) -> ServerResponse =>
    { status, headers: HeaderMap.new(), body: []u8.new(), stream: None, background: None, upgrade: None }

/// `text/plain; charset=utf-8` response.
#stable(since = "0.1")
export fn ServerResponse.text(status int, s str) -> ServerResponse {
    mut h = HeaderMap.new()
    ro _ = h.insert("Content-Type", "text/plain; charset=utf-8") // —Å—Ç–∞—Ç–∏—á–µ—Å–∫–æ–µ –∏–º—è ‚Äî –Ω–µ –º–æ–∂–µ—Ç –æ—Ç–∫–∞–∑–∞—Ç—å
    { status, headers: h, body: s.bytes(), stream: None, background: None, upgrade: None }
}

/// `text/html; charset=utf-8` response.
#stable(since = "0.1")
export fn ServerResponse.html(status int, s str) -> ServerResponse {
    mut h = HeaderMap.new()
    ro _ = h.insert("Content-Type", "text/html; charset=utf-8") // —Å—Ç–∞—Ç–∏—á–µ—Å–∫–æ–µ –∏–º—è ‚Äî –Ω–µ –º–æ–∂–µ—Ç –æ—Ç–∫–∞–∑–∞—Ç—å
    { status, headers: h, body: s.bytes(), stream: None, background: None, upgrade: None }
}

/// Raw-bytes response with an explicit Content-Type.
#stable(since = "0.1")
export fn ServerResponse.bytes(status int, content_type str, data []u8) -> ServerResponse {
    mut h = HeaderMap.new()
    ro _ = h.insert("Content-Type", content_type) // —Å—Ç–∞—Ç–∏—á–µ—Å–∫–æ–µ –∏–º—è ‚Äî –Ω–µ –º–æ–∂–µ—Ç –æ—Ç–∫–∞–∑–∞—Ç—å
    { status, headers: h, body: data, stream: None, background: None, upgrade: None }
}

/// Bodyless response (204/304/‚Ä¶).
#stable(since = "0.1")
export fn ServerResponse.empty(status int) -> ServerResponse =>
    { status, headers: HeaderMap.new(), body: []u8.new(), stream: None, background: None, upgrade: None }

/// Redirect response (`Location: location`).
#stable(since = "0.1")
export fn ServerResponse.redirect(status int, location str) -> ServerResponse {
    mut h = HeaderMap.new()
    ro _ = h.insert("Location", location) // —Å—Ç–∞—Ç–∏—á–µ—Å–∫–æ–µ –∏–º—è ‚Äî –Ω–µ –º–æ–∂–µ—Ç –æ—Ç–∫–∞–∑–∞—Ç—å
    { status, headers: h, body: []u8.new(), stream: None, background: None, upgrade: None }
}

// ‚îÄ‚îÄ Streamed response body ([M-178-server-streaming]) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
//
// A pull source for a streamed response body (`StreamBody`, declared above
// `ServerResponse` ‚Äî see the ordering note there): `@next_chunk()` is called
// repeatedly ‚Äî by `serve_once`'s pure/mock-test drain OR by
// `http.servernet`'s LIVE incremental socket writer ‚Äî until it returns
// `None` (end of stream). `f`'s body may block the CALLING fiber (e.g.
// `rx.recv()` on a `ChanReader` ‚Äî channel recv is a substrate primitive, not an
// algebraic effect, so no effect row is needed here, D22 closure-light rules);
// under the M:N fiber runtime (Plan 173/83.x substrate) that parks only this
// connection's fiber, not the whole event loop. Each chunk pulled is written to
// the socket with its own `write_all` (servernet.nv) ‚Äî the EXISTING `Net.write`
// park-on-full-buffer behaviour (std/net/tcp.nv `@write_all`) already IS the
// write-backpressure the deferred marker asked for; no new runtime primitive.

/// Wrap a closure as a streamed body's chunk source. `f` returns `None` at EOF.
#stable(since = "0.1")
export fn stream_body(f fn() -> Option[[]u8]) -> StreamBody => { f }

/// Pull the next chunk (`None` = end of stream).
#stable(since = "0.1")
export fn StreamBody @next_chunk() -> Option[[]u8] => (@f)()

/// Streamed body over a pre-built, finite list of chunks ‚Äî deterministic,
/// useful for tests/demos with a known event list. For a LIVE/unbounded source
/// (e.g. fan-out progress events arriving over time) wrap a `ChanReader.recv()`
/// loop in `stream_body(...)` directly instead (see server_test.nv for the
/// pattern).
#stable(since = "0.1")
export fn StreamBody.from_chunks(chunks [][]u8) -> StreamBody {
    mut idx = 0
    stream_body(|| {
        if idx < chunks.len() {
            ro c = chunks[idx]
            idx = idx + 1
            Some(c)
        } else {
            None
        }
    })
}

/// Streamed response (`Transfer-Encoding: chunked`; body pulled from
/// `producer` as the socket accepts writes). Use for any body whose total
/// length isn't known ahead of time; `ServerResponse.sse` below is the
/// `text/event-stream` specialisation. `[M-178-server-streaming]`
#stable(since = "0.1")
export fn ServerResponse.stream(status int, headers HeaderMap, producer StreamBody) -> ServerResponse =>
    { status, headers, body: []u8.new(), stream: Some(producer), background: None, upgrade: None }

/// `text/event-stream` (SSE) response ‚Äî sets the standard no-cache headers and
/// streams `producer`'s chunks as the raw SSE wire bytes (format each chunk
/// with `sse_event` below).
#stable(since = "0.1")
export fn ServerResponse.sse(producer StreamBody) -> ServerResponse {
    mut h = HeaderMap.new()
    ro _ = h.insert("Content-Type", "text/event-stream; charset=utf-8") // —Å—Ç–∞—Ç–∏—á–µ—Å–∫–æ–µ –∏–º—è ‚Äî –Ω–µ –º–æ–∂–µ—Ç –æ—Ç–∫–∞–∑–∞—Ç—å
    ro _ = h.insert("Cache-Control", "no-cache")
    ro _ = h.insert("X-Accel-Buffering", "no")
    { status: 200, headers: h, body: []u8.new(), stream: Some(producer), background: None, upgrade: None }
}

/// Whether this response streams its body via a chunk producer (vs. a fixed
/// in-memory buffer).
#stable(since = "0.1")
export fn ServerResponse @is_streaming() -> bool => @stream.is_some()

/// Take the stream producer (`None` for fixed-body responses). `StreamBody` is
/// a cheap value (closure handle, no owned resource) ‚Äî no move/consume
/// semantics needed.
#stable(since = "0.1")
export fn ServerResponse @take_stream() -> Option[StreamBody] => @stream

/// Attach `BackgroundTasks` to run AFTER this response's bytes are fully
/// written to the client (FastAPI `response.background`-analog, Plan
/// 222.16). Fluent setter (D117/D409): mutate-in-place + `-> @`, mirrors
/// `@header`/`@body` above.
#stable(since = "0.1")
export fn ServerResponse mut @background(tasks BackgroundTasks) -> @ {
    @background = Some(tasks)
}

/// Take the attached `BackgroundTasks` (`None` if the handler queued none).
/// The connection driver (`http.servernet.handle_connection`) calls this
/// AFTER writing the response to the socket, then `@drain()`s the result ‚Äî
/// see `background.nv`'s file banner for the graceful-shutdown TODO.
#stable(since = "0.1")
export fn ServerResponse @take_background() -> Option[BackgroundTasks] => @background

/// Mark this response as a protocol upgrade: `h` gets the live `TcpStream`
/// AFTER this response's bytes (the 101 handshake) are on the wire ‚Äî the
/// connection driver does NOT close/continue keep-alive on it afterward (see
/// `@take_upgrade`'s own doc-comment / the `upgrade` field's banner above).
/// Fluent setter (D117/D409), mirrors `@background` above.
#stable(since = "0.1")
export fn ServerResponse mut @upgrade(h fn(TcpStream) Net -> ()) -> @ {
    @upgrade = Some(h)
}

/// Take the attached upgrade hook (`None` for an ordinary response). The
/// connection driver (`http.servernet.serve_connection`, serve.nv) calls this
/// AFTER writing this response's bytes to the socket; `Some(h)` means: hand
/// the socket to `h` instead of the normal keep-alive continuation/close.
#stable(since = "0.1")
export fn ServerResponse @take_upgrade() -> Option[fn(TcpStream) Net -> ()] => @upgrade

/// Format one SSE event's wire bytes (WHATWG SSE): optional `event:` line +
/// one `data:` line per `\n`-separated line of `data` + the blank-line
/// terminator. Ready to hand straight to a `StreamBody` producer.
#stable(since = "0.1")
export fn sse_event(event str, data str) -> []u8 {
    consume sb = StringBuilder.new()
    sb.cap(32 + data.byte_len())
    if event.byte_len() > 0 {
        sb.append("event: ")
        sb.append(event)
        sb.append("\n")
    }
    for line in data.split("\n") {
        sb.append("data: ")
        sb.append(line)
        sb.append("\n")
    }
    sb.append("\n")
    sb.into_str().bytes()
}

/// Add/replace a response header. Mutating fleeting property (D117 AMEND-2):
/// a copying `@header` would shallow-copy the heap-backed `body` field,
/// sharing it with the pre-call response ‚Äî canon is mutate-in-place + `-> @`.
/// Total setter (`-> @`, no `Result`): the name/value here are handler-authored
/// literals, not network input ‚Äî an invalid name/CR-LF value is a caller bug,
/// so `insert` panics (`!!`) instead of silently swallowing the error. Dynamic
/// (network-derived) header values go through `headers().insert(n, v)?` directly.
#stable(since = "0.1")
export fn ServerResponse mut @header(name str, value str) -> @ {
    @headers.insert(name, value)!!
}

/// Copy with a REPLACED fixed body (`with_*` = NEW value, D117) ‚Äî status,
/// headers and stream marker preserved. For body-rewriting middleware
/// (`http.middleware.compress`, 222.12 –§.4); callers guard
/// `@is_streaming()` themselves ‚Äî replacing the fixed body of a streaming
/// response is meaningless (the producer wins on the wire).
/// Property-style by arity (D84/D117/D409): fluent setter returns `@`
/// (owner 2026-07-23: `with_body` was a second door ‚Äî retired pre-release).
#stable(since = "0.1")
export fn ServerResponse mut @body(data []u8) -> @ {
    @body = data
}

/// Status code (borrow).
#stable(since = "0.1")
export fn ServerResponse @status_code() -> int => @status

// ‚îÄ‚îÄ Handler (newtype over the fn type ‚Äî Go HandlerFunc, D52/D55) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

/// A request handler: a newtype over `fn(ServerRequest) -> ServerResponse`
/// (D52 form). A bare function or closure auto-lifts into `Handler` wherever
/// one is expected (D55 obvious single-wrapper coercion) ‚Äî registration reads
/// `r.get("/x", fn(req ServerRequest) -> ServerResponse { ... })`, no wrapper
/// call. A `Handler` value is invoked DIRECTLY: `h(req)` (call-through; the
/// one meaningful operation over a function forwards, Go `http.HandlerFunc`
/// precedent ‚Äî 222.3 ¬ß5–∞). NB (probed 2026-07-23): closure-light `|req| ...`
/// against a newtype-over-fn expectation mis-codegens its param as `nova_int`
/// ‚Äî spell handlers closure-FULL (`fn(req ServerRequest) -> ServerResponse`),
/// same known limitation middleware_test.nv documents for bare fn-types.
#stable(since = "0.1")
export type Handler fn(ServerRequest) -> ServerResponse

// ‚îÄ‚îÄ serve_once: the pure request‚Üíresponse driver (mock-testable, no sockets) ‚îÄ‚îÄ
//
// Routing itself (`Router` ‚Äî segment-trie, `MethodRouter`, precedence,
// `{param}`/`{*rest}`, nest/fallback) lives in router.nv (Plan 222.1; replaces
// the old linear-scan `ServeMux`, `[M-servemux-routing-placeholder]`).

/// Parse a raw HTTP/1.1 request and route it through `router` ‚Äî the routed
/// `ServerResponse`, WITHOUT serializing. Malformed request ‚Üí the same 400
/// `ServerResponse` `serve_once` would serialize. Exported so
/// `http.servernet`'s live socket runner can inspect `@is_streaming()`
/// before picking the fixed vs. chunked write path (`serve_once` stays the
/// single-shot pure entry point mock tests use).
#stable(since = "0.1")
export fn route_once(router Router, raw []u8) -> ServerResponse {
    match parse_request(raw) {
        Ok(req) => router.dispatch(req)
        Err(_)  => ServerResponse.text(400, "400 bad request")
    }
}

/// Same as `route_once`, but overrides the request's `multipart_limits`
/// snapshot before dispatch (`[M-222.11-multipart-limits-not-wired-to-
/// serverpolicy]`) ‚Äî the minimal-invasive channel from `ServerPolicy`
/// (`http.servernet`, cannot be imported here ‚Äî see `ServerRequest.
/// multipart_limits`'s own doc-comment) down to `Multipart.from_request`.
/// `router_callback_with_limits` (`server_serve.nv`) is the byte-level-
/// callback adapter that closes over `limits` for `http.serve.serve_router`
/// to use; ordinary callers keep using plain `route_once`/`router_callback`
/// (default `MultipartLimits.new()`, unchanged).
#stable(since = "0.1")
export fn route_once_with_multipart_limits(router Router, raw []u8, limits MultipartLimits) -> ServerResponse {
    match parse_request(raw) {
        Ok(req0) => {
            mut req = req0
            req.multipart_limits(limits)
            router.dispatch(req)
        }
        Err(_)  => ServerResponse.text(400, "400 bad request")
    }
}

/// Parse a raw HTTP/1.1 request, route it through `router`, and serialize the
/// response. The single unit reused by both the mock tests and the live socket
/// runner (http.servernet). Malformed request ‚Üí 400. A streaming response
/// (`@is_streaming()`) is fully drained HERE (mock-test/pure use ‚Äî the wire
/// bytes end up identical to what a real client receives, just materialized
/// eagerly instead of pushed incrementally); the live socket runner uses
/// `route_once` + `serialize_response_head`/`encode_chunk` directly for TRUE
/// incremental delivery ‚Äî that is the whole point of streaming, see
/// servernet.nv `handle_connection`.
#stable(since = "0.1")
export fn serve_once(router Router, raw []u8) -> []u8 {
    ro resp = route_once(router, raw)
    if resp.is_streaming() { drain_stream_to_bytes(resp) } else { serialize_response(resp) }
}

// ‚îÄ‚îÄ query / percent helpers ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn parse_query(q str) -> [](str, str) {
    mut out [](str, str) = []
    if q.byte_len() == 0 { return out }
    for pair in q.split("&") {
        if pair.byte_len() == 0 { continue }
        match pair.find("=") {
            Some(i) => out.push((percent_decode(pair[0..i]), percent_decode(pair[i + 1..pair.byte_len()])))
            None    => out.push((percent_decode(pair), ""))
        }
    }
    out
}

// Minimal percent-decode (+ ‚Üí space, %XX ‚Üí byte). Invalid escapes pass through.
fn percent_decode(s str) -> str {
    ro b = s.bytes()
    ro n = b.len()
    mut out []u8 = []u8.new(cap: n)
    mut i = 0
    while i < n {
        // Per-position transcode (`+`‚Üíspace, `%XX`‚Üídecoded byte, else‚Üípass-
        // through) ‚Äî not a contiguous-range copy, so no slice-view applies
        // here (¬ß18–∞); `cur` avoids the `push(x[i])` shape that the
        // W_MANUAL_SLICE_COPY heuristic flags for genuine range copies.
        ro cur = b[i] as int
        if cur == 0x2B {
            out.push(0x20)
            i += 1
        } else if cur == 0x25 && i + 2 < n {
            ro hi = hex_val(b[i + 1] as int)
            ro lo = hex_val(b[i + 2] as int)
            if hi >= 0 && lo >= 0 {
                out.push((hi * 16 + lo) as u8)
                i += 3
            } else {
                out.push(cur as u8)
                i += 1
            }
        } else {
            out.push(cur as u8)
            i += 1
        }
    }
    unsafe { out.to_str_unchecked() }
}

fn hex_val(c int) -> int {
    if c >= 0x30 && c <= 0x39 { c - 0x30 }
    else if c >= 0x61 && c <= 0x66 { c - 0x61 + 10 }
    else if c >= 0x41 && c <= 0x46 { c - 0x41 + 10 }
    else { -1 }
}

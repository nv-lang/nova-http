// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-http: server_serve.nv — `Router` → byte-level callback adapter (Plan
// 222 §0а layer contract, [M-178-server-policy-surface] refit 2026-07-23).
//
// WHY THIS FILE EXISTS: `http.servernet` (layer 1, the wire — accept loop,
// keep-alive, deadlines, body-size cap, chunked decode) must NEVER import
// `Router`/`route_once`/`Handler` (layer 2, routing/dispatch —
// `server.nv`/`server_router.nv`): a lower layer never imports a higher one
// (Plan 222 §0а, owner-fixed contract). `http.servernet.handle_connection`/
// `serve`/`serve_connection` therefore take a plain byte-level callback
// (`fn([]u8) -> ServerResponse`) instead of a `Router` directly.
// `router_callback` is that adapter — capturing `router` into a closure of
// the shape `servernet`'s primitives expect.
//
// NOT HERE: `handle_connection_router`/`serve_router` (the "just hand me a
// Router" one-call convenience wrappers) — those need to import BOTH
// `http.server` (for `Router`) AND `http.servernet` (for `handle_connection`/
// `serve`). Since `http.servernet` ALREADY imports FROM `http.server`
// (`ServerResponse`/`StreamBody`/the wire serializers — legitimate, NOT the
// layer violation; see `servernet.nv`'s own banner), adding a file to
// `http.server` that imports back FROM `http.servernet` makes the two
// modules mutually dependent — confirmed empirically during this refit: with
// `handle_connection_router`/`serve_router` defined HERE, `nova check` on any
// file that pulls in this module and `http.servernet` together fails with
// spurious `undefined identifier 'serialize_response'`/etc. inside
// `servernet.nv`/`serve.nv` — the module-resolution deadlock symptom of an
// A↔B cycle (http.server ⇄ http.servernet), not a real missing symbol
// (`serve.nv`/`servernet.nv` type-check CLEAN in isolation). Those two thin
// wrappers live in the genuinely third, standalone `http.serve` module
// (`../serve/serve.nv`) instead — the only file allowed to import BOTH
// layers, since neither layer imports FROM it (no cycle).
//
// Filename sorts alphabetically AFTER `server_router.nv` (folder-module
// peers compile in sorted order, D78/imports.rs `sib_paths.sort()`) — needs
// `Router`/`ServerResponse` already declared, same ordering rationale
// `server_router.nv`'s own banner documents for its position after
// `server.nv`.

module http.server

/// Wrap `router` as the raw-bytes callback `http.servernet`'s layer-1
/// primitives expect (`route_once` does the parse+dispatch; this just
/// captures `router` into a closure of the right shape). No import of
/// `http.servernet` needed here — this file only ever depends on symbols
/// already in THIS module (`Router`/`ServerResponse`/`route_once`), which is
/// exactly what keeps it cycle-free; see the file banner above for what
/// happens if a `http.servernet`-importing wrapper is added HERE instead of
/// in `http.serve`.
#stable(since = "0.1")
export fn router_callback(router Router) -> fn([]u8) -> ServerResponse => |raw| route_once(router, raw)

/// Same as `router_callback`, but closes over a `MultipartLimits` snapshot
/// (`[M-222.11-multipart-limits-not-wired-to-serverpolicy]`) instead of
/// `route_once`'s implicit default — `http.serve.serve_router` is the one
/// caller that has a `ServerPolicy` (and therefore `policy.multipart_limits()`)
/// available to pass here; see `route_once_with_multipart_limits`'s own
/// doc-comment (`server.nv`) for the full channel.
#stable(since = "0.1")
export fn router_callback_with_limits(router Router, limits MultipartLimits) -> fn([]u8) -> ServerResponse {
    // Destructure `limits` into three PLAIN `int`s BEFORE building the
    // closure, and DO NOT capture the `MultipartLimits` record itself —
    // `[M-closure-capture-value-struct-ptr-abi-mismatch]` (found wiring this
    // fn): a multi-field `value` record parameter is passed BY POINTER at
    // the C ABI level (`NovaValue_MultipartLimits* limits`, matching every
    // OTHER fn taking `MultipartLimits` in this package —
    // `parse_multipart_body`/`route_once_with_multipart_limits`), but
    // CAPTURING that same parameter into a closure's env struct declares the
    // env field BY VALUE (`NovaValue_MultipartLimits _nv_fv_..._limits`,
    // no `*`) — the generated capture-assignment then stores a pointer into
    // a value-typed field (CC-FAIL "assigning ... from incompatible type
    // ... dereference with *"), and the lambda body's own read-back,
    // needing to pass `limits` onward to a fn expecting the pointer ABI,
    // tries to re-derive a pointer from what is now a plain value
    // (`(&((*limits)))` — CC-FAIL "indirection requires pointer operand").
    // Reproduces regardless of closure-light vs closure-full syntax (both
    // lower through the SAME env-struct capture codegen). Three bare `int`s
    // (word-sized, unambiguous by-value capture, same shape `background.nv`'s
    // own `bool`/`str` captures already prove safe) sidestep the whole class
    // — reconstructed into a fresh `MultipartLimits` INSIDE the closure,
    // where it is a plain local, never captured. Report to integrator for
    // `docs/plans/backlog-followups.md` (this worktree does not touch the
    // nova repo).
    ro max_parts = limits.max_parts()
    ro max_part_size = limits.max_part_size()
    ro max_total = limits.max_total()
    fn(raw []u8) -> ServerResponse {
        mut lim = MultipartLimits.new()
        lim.max_parts(max_parts)
        lim.max_part_size(max_part_size)
        lim.max_total(max_total)
        route_once_with_multipart_limits(router, raw, lim)
    }
}

// SPDX-License-Identifier: MIT OR Apache-2.0
// Plan 222.3 ‚Äî `FromRequest` extractors: peer tests. –§.1 (ParamsDeserializer/
// QueryDeserializer ‚Äî pure parser tests, no http context) + –§.2 (`Bytes`/
// `Text`/`Headers` via `#impl(FromRequest)`, driven end-to-end through a real
// `Router` dispatch ‚Äî mirrors `router_test.nv`/`server_test.nv`'s own "build a
// raw HTTP/1.1 request, serve_once, inspect the wire response" style so no
// mock-`ServerRequest` constructor is needed).
//
// `PathParam[T]`/`Query[T]`/`Json[T]` round-trip tests (below, –§.2b) were
// blocked by `[M-generic-static-method-value-arg-addr-mismatch]` (221.1 ‚Ññ26:
// `SomeGeneric[Concrete].from_request(req)` emitted `&(req)` ‚Äî the
// argument's address ‚Äî at the call site while the generated callee took
// `req` BY VALUE, `unknown pointer‚Üívalue` CC-FAIL). CLOSED on nova main
// (`9300db349` "four parallel generic mono-instance signature paths never
// consulted the byref map", merged `4dc7c50f4`) ‚Äî reran with a nova.exe
// rebuilt from that commit, all three now PASS end-to-end.
//
// –§.3 (222.3 ¬ß5, arity-overload handler registration) tests are further
// below: `Router.@get`/`@post`/etc. with 0..N `FromRequest` extractors.

module http.server

import std.encoding.serde.{Serialize, Deserialize}

// `get_req` already defined in router_test.nv (same module, no re-declare).
fn post_json_req(path str, body str) -> []u8 =>
    "POST ${path} HTTP/1.1\r\nHost: x\r\nContent-Type: application/json\r\nContent-Length: ${body.byte_len()}\r\n\r\n${body}".bytes()
fn post_text_req(path str, body str) -> []u8 =>
    "POST ${path} HTTP/1.1\r\nHost: x\r\nContent-Length: ${body.byte_len()}\r\n\r\n${body}".bytes()

// ‚îÄ‚îÄ –§.1: ParamsDeserializer / QueryDeserializer ‚Äî pure parser tests ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

test "ParamsDeserializer: enter_field + deser_int/deser_str round-trip" {
    mut d = ParamsDeserializer.new([("id", "42"), ("name", "gizmo")])
    ro d1 = d.enter_field("id")!!
    mut d1m = d1
    assert(d1m.deser_int()!! == 42)
    ro d2 = d.enter_field("name")!!
    mut d2m = d2
    assert(d2m.deser_str()!! == "gizmo")
}

test "ParamsDeserializer: enter_field on a missing key -> MissingField error" {
    mut d = ParamsDeserializer.new([("id", "42")])
    ro r = d.enter_field("missing")
    assert(match r { Err(_) => true, Ok(_) => false })
}

test "ParamsDeserializer: has_field reflects presence" {
    mut d = ParamsDeserializer.new([("id", "42")])
    assert(d.has_field("id")!! == true)
    assert(d.has_field("nope")!! == false)
}

test "ParamsDeserializer: enter_field_or_null -> null cursor for a missing key" {
    mut d = ParamsDeserializer.new([("id", "42")])
    ro sub = d.enter_field_or_null("missing")!!
    mut subm = sub
    assert(subm.is_null()!! == true)
}

test "QueryDeserializer: percent-decode + '&'/'=' split, then enter_field + deser" {
    mut d = QueryDeserializer.new("q=hello%20world&limit=10")
    ro d1 = d.enter_field("q")!!
    mut d1m = d1
    assert(d1m.deser_str()!! == "hello world")
    ro d2 = d.enter_field("limit")!!
    mut d2m = d2
    assert(d2m.deser_int()!! == 10)
}

test "QueryDeserializer: empty query string -> no fields present" {
    mut d = QueryDeserializer.new("")
    assert(d.has_field("anything")!! == false)
}

// ‚îÄ‚îÄ Bytes / Text / Headers : FromRequest (never fail on well-formed UTF-8) ‚îÄ

test "Bytes: raw body bytes, no decode" {
    mut r = Router.new()
    r.post("/raw", handler_fn(|req| {
        match Bytes.from_request(req) {
            Ok(b)  => ServerResponse.text(200, "len=${b.data().len()}")
            Err(e) => e.into_response()
        }
    }))!!
    ro wire = serve_once(r, post_text_req("/raw", "hello"))
    ro s = unsafe { wire.to_str_unchecked() }
    assert(s.contains("len=5"))
}

test "Text: body as UTF-8 text" {
    mut r = Router.new()
    r.post("/echo", handler_fn(|req| {
        match Text.from_request(req) {
            Ok(t)  => ServerResponse.text(200, "got=${t.data()}")
            Err(e) => e.into_response()
        }
    }))!!
    ro wire = serve_once(r, post_text_req("/echo", "hello there"))
    ro s = unsafe { wire.to_str_unchecked() }
    assert(s.contains("got=hello there"))
}

test "Headers: exposes the request's header map" {
    mut r = Router.new()
    r.get("/hdrs", handler_fn(|req| {
        match Headers.from_request(req) {
            Ok(h) => match h.data().get("Host") {
                Some(_) => ServerResponse.text(200, "has-host")
                None    => ServerResponse.text(200, "no-host")
            }
            Err(e) => e.into_response()
        }
    }))!!
    ro wire = serve_once(r, get_req("/hdrs"))
    ro s = unsafe { wire.to_str_unchecked() }
    assert(s.contains("has-host"))
}

// ‚îÄ‚îÄ –§.2b: PathParam[T] / Query[T] / Json[T] ‚Äî round-trip through a real
// Router dispatch (closes 221.1 ‚Ññ26, [M-generic-static-method-value-arg-
// addr-mismatch]; see this file's banner) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

#impl(Serialize + Deserialize)
type UserIdParams value { ro id int }

#impl(Serialize + Deserialize)
type SearchQuery value { ro q str, ro limit int }

#impl(Serialize + Deserialize)
type CreateItem value { ro name str, ro qty int }

test "PathParam[T]: round-trip through Router dispatch" {
    mut r = Router.new()
    r.get("/users/{id}", handler_fn(|req| {
        match PathParam[UserIdParams].from_request(req) {
            Ok(p)  => ServerResponse.text(200, "id=${p.data().id}")
            Err(e) => e.into_response()
        }
    }))!!
    ro wire = serve_once(r, get_req("/users/42"))
    ro s = unsafe { wire.to_str_unchecked() }
    assert(s.contains("id=42"))
}

test "PathParam[T]: bad int -> HttpError, not a crash" {
    mut r = Router.new()
    r.get("/users/{id}", handler_fn(|req| {
        match PathParam[UserIdParams].from_request(req) {
            Ok(p)  => ServerResponse.text(200, "id=${p.data().id}")
            Err(e) => e.into_response()
        }
    }))!!
    ro wire = serve_once(r, get_req("/users/not-a-number"))
    assert(status_line(wire) == "HTTP/1.1 400 Bad Request")
}

test "Query[T]: round-trip through Router dispatch" {
    mut r = Router.new()
    r.get("/search", handler_fn(|req| {
        match Query[SearchQuery].from_request(req) {
            Ok(q)  => ServerResponse.text(200, "q=${q.data().q} limit=${q.data().limit}")
            Err(e) => e.into_response()
        }
    }))!!
    ro wire = serve_once(r, get_req("/search?q=widgets&limit=10"))
    ro s = unsafe { wire.to_str_unchecked() }
    assert(s.contains("q=widgets limit=10"))
}

test "Json[T]: round-trip through Router dispatch" {
    mut r = Router.new()
    r.post("/items", handler_fn(|req| {
        match Json[CreateItem].from_request(req) {
            Ok(j)  => ServerResponse.text(200, "name=${j.data().name} qty=${j.data().qty}")
            Err(e) => e.into_response()
        }
    }))!!
    ro wire = serve_once(r, post_json_req("/items", "{\"name\":\"gizmo\",\"qty\":5}"))
    ro s = unsafe { wire.to_str_unchecked() }
    assert(s.contains("name=gizmo qty=5"))
}

test "Json[T]: malformed body -> HttpError, not a crash" {
    mut r = Router.new()
    r.post("/items", handler_fn(|req| {
        match Json[CreateItem].from_request(req) {
            Ok(j)  => ServerResponse.text(200, "name=${j.data().name}")
            Err(e) => e.into_response()
        }
    }))!!
    ro wire = serve_once(r, post_json_req("/items", "{not json"))
    assert(status_line(wire) == "HTTP/1.1 400 Bad Request")
}

// ‚îÄ‚îÄ –§.3: PathParam + Query + Json composed on ONE route (222.3 ¬ß5 gate item
// #4) ‚Äî arity-overload SUGAR (`r.post[PathParam[X], Query[Y], Json[Z], R](‚Ä¶)`)
// is BLOCKED (see extract.nv banner, [M-concrete-instance-arity-overload-
// mangle]); this is the low-level `Handler` + manual per-extractor
// composition the banner names as the surviving registration path ‚Äî
// `ServerRequest` is `value`, so all three extractors read it independently,
// no ownership conflict. Also exercises: adding a NEW route to a `Router`
// that ALSO carries plain (no-extractor) routes doesn't disturb 404/405
// (shared `Router` with the plain `/health` route below). ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

test "PathParam+Query+Json composed on one route; 404/405 unaffected on the same Router" {
    mut r = Router.new()
    r.get("/health", handler_fn(|req| ServerResponse.text(200, "ok")))!!
    r.post("/items/{id}", handler_fn(|req| {
        match PathParam[UserIdParams].from_request(req) {
            Ok(p) => match Query[SearchQuery].from_request(req) {
                Ok(q) => match Json[CreateItem].from_request(req) {
                    Ok(j)  => ServerResponse.text(200, "id=${p.data().id} q=${q.data().q} name=${j.data().name}")
                    Err(e) => e.into_response()
                }
                Err(e) => e.into_response()
            }
            Err(e) => e.into_response()
        }
    }))!!

    // happy path: all three extractors succeed
    ro wire = serve_once(r, post_json_req("/items/7?q=widgets&limit=1", "{\"name\":\"gizmo\",\"qty\":5}"))
    ro s = unsafe { wire.to_str_unchecked() }
    assert(s.contains("id=7 q=widgets name=gizmo"))

    // the plain no-extractor route on the SAME Router is unaffected
    ro wire_health = serve_once(r, get_req("/health"))
    assert(status_line(wire_health) == "HTTP/1.1 200 OK")

    // 404: no route matches at all
    ro wire_404 = serve_once(r, get_req("/nope"))
    assert(status_line(wire_404) == "HTTP/1.1 404 Not Found")

    // 405: path matches (/items/{id}) but method doesn't (only POST registered)
    ro wire_405 = serve_once(r, get_req("/items/7"))
    assert(status_line(wire_405) == "HTTP/1.1 405 Method Not Allowed")
}

// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-http: respond.nv ‚Äî `IntoResponse` protocol + typed-status `ServerResponse`
// constructors (Plan 222.5, `polaris.respond`). Everything an HTTP handler can
// return collapses to a `ServerResponse` through ONE protocol:
//   `str` / `StatusCode` / `ServerResponse` (identity) / `Json[T Serialize]` /
//   `HttpError` / the blanket `Result[R IntoResponse, E IntoResponse]` (gives
//   `?`-ergonomics in handlers for free ‚Äî mirrors the `Option`/`Result`
//   `Debug`/`Display` blanket precedent, std/prelude/protocols.nv).
//
// File placement: peer of `server.nv`/`server_router.nv` in the SAME module
// (`http.server`) ‚Äî folder-module peers compile in sorted order (D78), and
// this file's name sorts AFTER `server.nv` (needs `ServerResponse`/`Handler`
// already declared) ‚Äî same rationale as `server_router.nv`'s own banner.
// Unlike `server_router.nv`'s `RouteNode`/`MethodEntry`, nothing declared here
// embeds another module type BY VALUE inside a NEW struct (`Json[T]` holds a
// generic `T`, monomorphized per instantiation) ‚Äî so this file does not
// itself need to sort after `server_router.nv`; ordering vs `server_router.nv`
// is irrelevant (`extract.nv`, Plan 222.3, is the one that needs `Router`
// AND `Json[T]`/`IntoResponse` from here, so it must sort after BOTH ‚Äî see
// that file's own banner).
//
// ¬ß5 open questions (222.5 plan) resolved (–§.0, verified not guessed):
//   1. Tuple-impl `(StatusCode, R IntoResponse) : IntoResponse` ‚Äî no working
//      precedent for a `#impl` on a bare tuple TYPE anywhere in std (grepped);
//      the plan's own fallback applies: `ServerResponse.json(status, v)` (or
//      `.header()` chaining on the built response) covers the "status + body"
//      shape without inventing tuple-receiver syntax. NOT implemented.
//   2. `HttpError.into_response()` status/body mapping ‚Äî status by `ErrorKind`
//      (see `http_error_status` below: transport-class kinds ‚Üí 503, decode/
//      protocol/url/header kinds ‚Üí 400, `Status(c)` echoes `c`, `BodyTooLarge`
//      ‚Üí 413, `Blocked` ‚Üí 403, everything else ‚Üí 500); body is JSON
//      `{"error": "<kind name>", "message": "<to_str()>"}` (FastAPI-class
//      shape ‚Äî structured, not bare text) via the SAME `Serialize`
//      auto-derive machine as any other record (`HttpErrorBody` below).

module http.server

import http.{StatusCode, HttpError, ErrorKind}
import std.encoding.serde.{Serialize, SerError, json_encode}

// ‚îÄ‚îÄ IntoResponse protocol ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

/// Everything an HTTP handler can return converges here ‚Äî lets handlers write
/// `-> Result[Json[User], HttpError]` instead of hand-assembling `ServerResponse`.
#stable(since = "0.1")
export type IntoResponse protocol {
    consume @into_response() -> ServerResponse
}

// ‚îÄ‚îÄ StatusCode-typed constructors (¬ß4 ‚Äî chinit ¬´—Å—Ç–∞—Ç—É—Å –≥–æ–ª—ã–º int¬ª) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// MOVED to server.nv (plan 222.5 ¬ß4–∞ item 3, unification wave): now that
// `ServerResponse.status` itself is `StatusCode` (not `int`), the
// `StatusCode`-typed overloads of `.text`/`.html`/`.bytes`/`.empty`/`.redirect`
// ARE the canonical constructors declared right next to the struct ‚Äî no more
// `.as_u16() as int` delegation cast-bridge into a separate bare-`int` form
// (`[M-statuscode-u16-cast-bounce]`, CLOSED here). The bare-`int` overloads
// stay in server.nv too, now DEPRECATED (source-compat bridge over
// `unsafe { StatusCode.new_unchecked }`, ~90 existing call-sites across the
// package left untouched ‚Äî soft migration, not a mass site-rewrite this
// wave).

// ‚îÄ‚îÄ Json[T] ‚Äî response body wrapper (double duty, Axum-parity: the SAME type
// also gets a `#impl(FromRequest)` in extract.nv, Plan 222.3, for the request
// side ‚Äî declared HERE because the `IntoResponse` impl below needs it and
// 222.5 lands before/with 222.3, plan ¬ß1). ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

/// A JSON request/response body wrapper ‚Äî `json(v).into_response()` on
/// the way out, `Json[T].from_request(req)` (extract.nv) on the way in.
///
/// NOT `value` (deviates from plan ¬ß2's literal `Json[T] value {...}`) ‚Äî
/// [M-generic-value-self-protocol-wrapper-mono] CLOSED –û–ö–ù–û–ú-3 (value restored; original minimal
/// repro below): a GENERIC `value`-kind type conforming to a protocol whose
/// method has NO method-level generic param and returns `Result[Self, E]` (or
/// `Option[Self]`) makes the forward-decl pass emit an invalid C struct
/// instantiated on the BARE typevar name itself (`NovaValue_Json____Nova_T_p`
/// ‚Äî literal "T", never substituted) alongside the correctly-monomorphized
/// concrete ones ‚Äî `unknown type name`, CC-FAIL. Reproduces with a 12-line
/// minimal case unrelated to Json/HttpError (`type Wrap[T] value {...}` +
/// `type P protocol { .m(x int) -> Result[Self, E] }` + `fn Wrap[T
/// Equal].m(...) -> Result[Wrap[T], E]`); reproduces with `Option[Self]` too
/// (not Result-specific). Two workarounds confirmed: (a) give the protocol
/// method its OWN method-level generic param (`.m[D](...)`, mirrors
/// `Deserialize.deserialize[D Deserializer]`'s shape ‚Äî but that changes
/// `FromRequest`'s signature, not authorized by the plan); (b) drop `value`
/// (this type becomes a normal heap/GC'd reference type ‚Äî the one applied
/// here, smallest surface change, no protocol-signature deviation). Does NOT
/// affect NON-generic conformers (`Bytes`/`Text`/`Headers` in extract.nv stay
/// `value` ‚Äî confirmed unaffected). Report to integrator for
/// `docs/plans/backlog-followups.md` registration + plan 222.3/222.5
/// ¬ß2-amendment (this worktree does not touch the nova repo).
#stable(since = "0.1")
export type Json[T] value { priv data T }

/// The wrapped value (property accessor, D117 ‚Äî not a bare field).
#stable(since = "0.1")
export fn Json[T] @data() -> T => @data

/// Wrap a value as a `Json[T]` body. FREE FUNCTION, not `Json.new[T](...)` ‚Äî
/// [M-generic-value-static-ctor-mangle] (found + isolated during this wave,
/// minimal repro below): a namespace-static constructor `TypeName.method[T](v
/// T) -> TypeName[T]` on a generic `value`-kind type, called with an
/// INFERRED (non-turbofish) `T`, emits the WRONG C type for both (a) a local
/// binding `ro x = TypeName.method(v)` (`Nova_TypeName____<T>` ‚Äî pointer/
/// reference-kind naming ‚Äî instead of the correct value-kind
/// `NovaValue_TypeName____<T>`) and (b) the constructor result chained
/// straight into another instance-method call (passes the struct BY VALUE
/// where the receiver parameter is a pointer). Reproduces with T = a
/// user-defined `value` record AND with T = a bare primitive (`int`) ‚Äî not
/// specific to `Json`/`Widget`; reproduces regardless of the constructor's
/// name (`.new`/`.make`/‚Ä¶) ‚Äî not a `.new`-specific quirk. A FREE function
/// with the identical generic-return shape (`fn box_iter[T](it VecIter[T]) ->
/// BoxIter[T]`, std/collections/vec_lazy/core.nv ‚Äî pre-existing precedent for
/// this exact style) is NOT affected ‚Äî the type is inferred correctly for
/// both the local-binding and chained-call shapes. Repro (isolated, 10
/// lines): `export type Box[T] value { priv data T }` +
/// `export fn Box.make[T](v T) -> Box[T] => { data: v }` + `ro b =
/// Box.make(42)` ‚Üí CC-FAIL `unknown type name 'Nova_Box____nova_int'`. Report
/// to integrator for `docs/plans/backlog-followups.md` registration (this
/// worktree does not touch the nova repo).
#stable(since = "0.1")
export fn json[T](v T) -> Json[T] => { data: v }

/// One-call JSON response: encode `v` (`#impl(Serialize)`) with
/// `Content-Type: application/json` + the given status. Replaces manual
/// `serdejson`-plumbing for server responses (plan ¬ß3). A `SerError` (non-
/// finite float / depth-limit / lossy-integer ‚Äî all programmer bugs on the
/// SERIALIZE side, not request input) collapses to a 500 with the detail in
/// the body ‚Äî there is no sane 4xx mapping for "the handler's own DTO failed
/// to encode".
#stable(since = "0.1")
export fn ServerResponse.json[T Serialize](status StatusCode, v T) -> ServerResponse {
    match json_encode(v) {
        Ok(s)  => ServerResponse.bytes(status, "application/json", s.bytes())
        Err(e) => server_json_encode_error(e)
    }
}

fn server_json_encode_error(e SerError) -> ServerResponse =>
    ServerResponse.text(StatusCode.INTERNAL_SERVER_ERROR, "500 internal server error: ${e.to_str()}")

// ‚îÄ‚îÄ IntoResponse impls (the bulk of this plan's value ‚Äî blanket Result[R,E]
// gives `?`-ergonomics in handlers for free) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

/// Identity ‚Äî a handler that already built its `ServerResponse` passes through.
#impl(IntoResponse)
export fn ServerResponse consume @into_response() -> ServerResponse => @

/// A bare `str` becomes a `200 OK` `text/plain` response.
#impl(IntoResponse)
export fn str consume @into_response() -> ServerResponse => ServerResponse.text(StatusCode.OK, @)

/// A bare `StatusCode` becomes a bodyless response at that status.
#impl(IntoResponse)
export fn StatusCode consume @into_response() -> ServerResponse => ServerResponse.empty(@)

/// `Json[T Serialize]` becomes a `200 OK` `application/json` response.
#impl(IntoResponse)
export fn Json[T Serialize] consume @into_response() -> ServerResponse =>
    ServerResponse.json(StatusCode.OK, @data())

/// Structured error body ‚Äî `{"error": "<kind>", "message": "<detail>"}`, status
/// from `http_error_status` below (¬ß5.2 resolution, this file's banner).
#impl(Serialize)
type HttpErrorBody value { ro error str, ro message str }

fn http_error_kind_name(kind ErrorKind) -> str {
    match kind {
        Connect             => "connect"
        Dns                 => "dns"
        Tls                 => "tls"
        Timeout             => "timeout"
        Protocol(_)         => "protocol"
        InvalidUrl          => "invalid_url"
        InvalidHeader       => "invalid_header"
        Status(_)           => "status"
        TooManyRedirects(_) => "too_many_redirects"
        BodyTooLarge        => "body_too_large"
        Closed              => "closed"
        Canceled            => "canceled"
        Blocked(_)          => "blocked"
        Other(_)            => "other"
    }
}

fn http_error_status(kind ErrorKind) -> StatusCode {
    match kind {
        Connect             => StatusCode.SERVICE_UNAVAILABLE
        Dns                 => StatusCode.SERVICE_UNAVAILABLE
        Tls                 => StatusCode.SERVICE_UNAVAILABLE
        Timeout             => StatusCode.SERVICE_UNAVAILABLE
        Protocol(_)         => StatusCode.BAD_REQUEST
        InvalidUrl          => StatusCode.BAD_REQUEST
        InvalidHeader       => StatusCode.BAD_REQUEST
        Status(c)           => c
        TooManyRedirects(_) => StatusCode.INTERNAL_SERVER_ERROR
        BodyTooLarge        => StatusCode.PAYLOAD_TOO_LARGE  // 413 Content Too Large
        Closed              => StatusCode.SERVICE_UNAVAILABLE
        Canceled            => StatusCode.SERVICE_UNAVAILABLE
        Blocked(_)          => StatusCode.FORBIDDEN
        Other(_)            => StatusCode.INTERNAL_SERVER_ERROR
    }
}

/// `HttpError` ‚Üí a typed status (by `kind`) + a structured JSON error body.
#impl(IntoResponse)
export fn HttpError consume @into_response() -> ServerResponse =>
    ServerResponse.json(http_error_status(@kind), HttpErrorBody{ error: http_error_kind_name(@kind), message: @to_str() })

/// BLANKET ‚Äî `Result[R IntoResponse, E IntoResponse]` : `IntoResponse`. Gives
/// `?`-ergonomics in handlers for free (a handler can end in `foo()?` and
/// `-> Result[R, HttpError]` directly, no manual `match`). Mirrors the
/// `Option`/`Result` `Debug`/`Display` blanket precedent (std/prelude/
/// protocols.nv `fn Result[T Display, E Display] @display(...)`).
#impl(IntoResponse)
export fn Result[R IntoResponse, E IntoResponse] consume @into_response() -> ServerResponse {
    match @ {
        Ok(r)  => r.into_response()
        Err(e) => e.into_response()
    }
}

/// BLANKET ‚Äî auto-JSON (owner-go 2026-07-23, 222 ¬ß0–≤ –ø.2, probe p1): ANY
/// `T Serialize` becomes a `200 OK` `application/json` response ‚Äî `Ok(user)`
/// in a handler needs no `Json{}` wrapper (Axum's `Json(user)` ergonomics
/// without the wrapper). D355 bare-typevar-receiver blanket; dispatch
/// priority verified by probe p1 (branch p222-0v-probes): a CONCRETE impl on
/// the same protocol (`str` ‚Üí text/plain above) WINS over this blanket
/// (D285), and the `Result[R,E]` generic-type impl above coexists with it
/// (probe p1b ‚Äî different receiver-class, no E_BLANKET_CONFLICT). Bare
/// scalars are INCLUDED (owner decision): `Ok(42)` ‚Üí JSON `42`.
///
/// DECLARATION ORDER MATTERS (pinned by respond_test's scalar pins): this
/// blanket must come AFTER the `Result[R,E]` generic impl above ‚Äî with the
/// blanket declared FIRST, a PRIMITIVE receiver's blanket call (`42
/// .into_response()`, direct or via the Result Ok-arm) mangles to the LAST
/// generic impl's receiver head instead of the substituted typevar
/// (`Nova_Result_consume_into_response(nova_int)` ‚Äî undefined symbol,
/// CC-FAIL; records are unaffected either way). Same order both probes used
/// (blanket last). Reported to integrator (this worktree does not touch the
/// nova repo).
#impl(IntoResponse)
export fn[T Serialize] T consume @into_response() -> ServerResponse =>
    ServerResponse.json(StatusCode.OK, @)

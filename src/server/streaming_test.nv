// SPDX-License-Identifier: MIT OR Apache-2.0
// [M-178-server-streaming] (force-impl, Plan 116 worktree) — streaming/SSE
// response body over the pure server core (mock-driven, no sockets).
//
// `serve_once` fully drains the `StreamBody` producer into ONE byte buffer
// (`drain_stream_to_bytes`, wire.nv) — the wire BYTES are identical to what a
// real client receives over the LIVE incremental socket writer
// (http.servernet `handle_connection`/`write_streaming`), so this pure/
// mock path is a faithful test of the chunked-transfer wire FORMAT without
// sockets (D361 mock-first). The live-socket smoke test proving the
// INCREMENTAL delivery itself lives in servernet/rt/streaming_smoke.nv.

module http.server

fn streaming_routes() -> Router {
    mut r = Router.new()
    r.get("/events", fn(req ServerRequest) -> ServerResponse {
        ro chunks [][]u8 = ["a".bytes(), "bcd".bytes()]
        ServerResponse.stream(200, HeaderMap.new(), StreamBody.from_chunks(chunks))
    })!!
    r.get("/sse", fn(req ServerRequest) -> ServerResponse {
        ro chunks [][]u8 = [sse_event("tick", "1"), sse_event("tick", "2"), sse_event("done", "bye")]
        ServerResponse.sse(StreamBody.from_chunks(chunks))
    })!!
    r
}

// `status_line` is defined in mux_test.nv (same module — peer-file namespace,
// no import/redeclare needed).

// ── wire format: Transfer-Encoding: chunked, no Content-Length ────────────────

test "server: streaming response — Transfer-Encoding: chunked, no Content-Length" {
    ro req = "GET /events HTTP/1.1\r\nHost: x\r\n\r\n".bytes()
    ro wire []u8 = serve_once(streaming_routes(), req)
    ro s = unsafe { wire.to_str_unchecked() }
    assert(status_line(wire) == "HTTP/1.1 200 OK")
    // `Transfer-Encoding`/`Connection` are literal Title-Case writes in
    // `serialize_response_head` (wire.nv) — same convention as the existing
    // `serialize_response`'s auto-added `Content-Length`/`Connection` (see
    // mux_test.nv's `"Content-Length: 5"` assertion); ONLY HeaderMap-routed
    // headers (Content-Type/Cache-Control below) get lowercased by `nm.str()`.
    assert(s.contains("Transfer-Encoding: chunked"))
    assert(!s.contains("content-length"))
}

// ── wire format: chunk framing is hex-size CRLF data CRLF (RFC 9112 §7.1) ─────

test "server: streaming response — chunk framing is hex-size CRLF data CRLF" {
    ro req = "GET /events HTTP/1.1\r\nHost: x\r\n\r\n".bytes()
    ro wire []u8 = serve_once(streaming_routes(), req)
    ro s = unsafe { wire.to_str_unchecked() }
    assert(s.contains("1\r\na\r\n"))
    assert(s.contains("3\r\nbcd\r\n"))
}

test "server: streaming response — terminated by the 0-size chunk" {
    ro req = "GET /events HTTP/1.1\r\nHost: x\r\n\r\n".bytes()
    ro wire []u8 = serve_once(streaming_routes(), req)
    ro s = unsafe { wire.to_str_unchecked() }
    assert(s.ends_with("0\r\n\r\n"))
}

// ── SSE: text/event-stream headers + event/data framing ───────────────────────

test "server: SSE response — text/event-stream headers + event/data framing" {
    ro req = "GET /sse HTTP/1.1\r\nHost: x\r\n\r\n".bytes()
    ro wire []u8 = serve_once(streaming_routes(), req)
    ro s = unsafe { wire.to_str_unchecked() }
    assert(status_line(wire) == "HTTP/1.1 200 OK")
    assert(s.contains("content-type: text/event-stream"))
    assert(s.contains("cache-control: no-cache"))
    assert(s.contains("event: tick\ndata: 1\n\n"))
    assert(s.contains("event: tick\ndata: 2\n\n"))
    assert(s.contains("event: done\ndata: bye\n\n"))
    assert(s.ends_with("0\r\n\r\n"))
}

// ── edge: zero chunks still writes a well-formed head + terminator ────────────

test "server: empty stream (zero chunks) still writes head + terminator" {
    mut r = Router.new()
    r.get("/empty", fn(req ServerRequest) -> ServerResponse {
        ro chunks [][]u8 = []
        ServerResponse.stream(200, HeaderMap.new(), StreamBody.from_chunks(chunks))
    })!!
    ro req = "GET /empty HTTP/1.1\r\nHost: x\r\n\r\n".bytes()
    ro wire []u8 = serve_once(r, req)
    ro s = unsafe { wire.to_str_unchecked() }
    assert(status_line(wire) == "HTTP/1.1 200 OK")
    assert(s.contains("Transfer-Encoding: chunked")) // Title-Case — see the first test above
    assert(s.ends_with("0\r\n\r\n"))
}

// ── the real 187-shaped pattern: a producer pulled from a ChanReader ──────────
//
// Fan-out SIGNALS arriving over a channel drive which pre-formatted SSE chunk
// the producer emits next — the whole reason streaming is needed over a fixed
// body. Pre-seeded + closed here so the pull is deterministic without sockets/
// fibers; the LIVE version (real fiber producer, real time) is exactly this
// shape — see docs/channels.md.
//
// The channel carries `int` indices, NOT the `[]u8`/`str` chunk payload
// itself: `Channel.new(n)`'s element-type inference (docs/channels.md "T is
// inferred from the first send/recv") only reliably resolves to `int`
// end-to-end today — a non-`int` first `send` (`str`, or `[]u8` as tried here
// first) silently mistypes the channel's C element field as `nova_int` and
// bit-reinterprets the payload pointer through it (found live via this test:
// str failed loud as a CC-FAIL pointer/struct mismatch, `[]u8` "compiled" via
// C's implicit pointer→int conversion but is NOT a sound fix), and the
// documented turbofish escape hatch `Channel[str].new(n)` crashes the compiler
// (`internal error … [P67-LEGACY] Ident \`Channel\` not in var_types`, isolated
// repro confirmed pre-existing/unrelated to server-streaming). Both reported
// separately (`[M-channel-generic-elem-type]`, backlog-followups.md) — out of
// this marker's scope (compiler-codegen, not std/http). `int` events here are
// a safe, still-realistic stand-in (e.g. "row N changed" signals mapped to
// pre-rendered payloads is a normal SSE shape too).

fn chan_events() -> [][]u8 => [sse_event("msg", "first"), sse_event("msg", "second")]

test "server: streaming response driven by a ChanReader producer" {
    ro { tx, rx } = Channel.new(4)
    tx.send(0)
    tx.send(1)
    tx.close()
    ro events = chan_events()
    ro producer = stream_body(|| {
        match rx.recv() {
            Some(idx) => Some(events[idx])
            None      => None
        }
    })
    mut r = Router.new()
    r.get("/chan", fn(req ServerRequest) -> ServerResponse => ServerResponse.sse(producer))!!
    ro req = "GET /chan HTTP/1.1\r\nHost: x\r\n\r\n".bytes()
    ro wire []u8 = serve_once(r, req)
    ro s = unsafe { wire.to_str_unchecked() }
    assert(s.contains("event: msg\ndata: first\n\n"))
    assert(s.contains("event: msg\ndata: second\n\n"))
    assert(s.ends_with("0\r\n\r\n"))
}

test "server: ServerResponse.is_streaming distinguishes fixed vs. streamed" {
    ro fixed = ServerResponse.text(200, "ok")
    ro chunks [][]u8 = ["x".bytes()]
    ro streamed = ServerResponse.stream(200, HeaderMap.new(), StreamBody.from_chunks(chunks))
    assert(!fixed.is_streaming())
    assert(streamed.is_streaming())
}

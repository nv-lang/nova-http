// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-http: server_router.nv — Axum-class HTTP router (Plan 222.1). Replaces
// the old `ServeMux` (linear scan, 1-segment `{param}` only, first-match-by-
// registration-order — `[M-servemux-routing-placeholder]`). Filename sorts
// alphabetically AFTER `server.nv` (folder-module peers compile in sorted
// order, D78/imports.rs `sib_paths.sort()`) — `MethodEntry`/`RouteNode` embed
// `Handler` (declared in `server.nv`) BY VALUE, which needs `Handler`'s C
// struct already complete at THIS file's struct-declaration site; a plain
// `router.nv` sorts BEFORE `server.nv` and CC-FAILs ("incomplete type
// NovaValue_Handler").
//
// `Router` is a segment-trie (arena of `RouteNode`s, indices instead of nested
// owned pointers — sidesteps recursive-value-mutation entirely: every mutation is
// a read-modify-write on `@nodes[idx]`, see `@insert_segs` below): literal
// segments, `{name}` (one segment), `{*name}` (catch-all, must be the LAST
// segment). Precedence at dispatch is structural (`@match_from`'s try-order:
// literal → param → catch-all, backtracking on a deeper dead end) — NOT
// registration order, unlike the old ServeMux.
//
// `MethodRouter` is Axum's composable per-route method dispatch object
// (`get(h).post(h2)`) — a `Router.route(path, mr)` registers one `MethodRouter`
// at `path`; the single-method sugar (`Router.@get(path, h)` etc.) builds a
// throwaway one-method `MethodRouter` under the hood. 405 (path matched, method
// did not) first tries the matched `MethodRouter`'s OWN `@fallback` (per-route
// override), then falls through to the wire `405 + Allow` response.
//
// Route conflicts (exact-duplicate path registration, OR two different `{name}`
// param names claiming the same trie slot) are a typed `Result` at REGISTRATION
// time (`HttpError` with `ErrorKind.Other` detail) — Axum panics on the
// equivalent; typed-Result-not-panic is the deliberate improvement the plan
// calls for (§2, "мы лучше Axum").
//
// `Router.nest(prefix, sub)` merges `sub`'s already-conflict-free route tree
// into `self` at `prefix` (re-running the SAME conflict-checked insertion per
// collected route) — `sub`'s own `@fallback` is intentionally NOT threaded
// through (only the top-level `Router.fallback` / per-route `MethodRouter.
// fallback` are in the plan's scope, §2 point 4); documented simplification,
// not a gap the plan asks to close.

module http.server

import http.{HttpError, ErrorKind}

// ── MethodRouter (composable per-route method dispatch) ───────────────────────

/// A composable method-dispatch object for one route: `get(h).post(h2)` chains
/// onto ONE `MethodRouter`, then `Router.route(path, mr)` registers the whole
/// set atomically. `@fallback` (property, D84) is the PER-ROUTE 405 override —
/// distinct from `Router.@fallback` (global 404).
// `(str, Handler)` tuple-element Vecs aren't exercised elsewhere in this
// package (unlike the well-trodden `[](str, str)`) — a small named record
// sidesteps relying on that untested tuple-monomorphization path.
type MethodEntry value { ro method str, ro handler Handler }

#stable(since = "0.1")
export type MethodRouter value {
    mut routes   []MethodEntry
    mut fallback Option[Handler]
}

/// Empty method-set (no methods registered yet).
#stable(since = "0.1")
export fn MethodRouter.new() -> MethodRouter => { routes: []MethodEntry.new(), fallback: None }

/// Independent copy (D246 canon (b) — see `middleware.nv`'s `wrap_method_
/// router` for the one call site and why an in-out `mut` param doesn't fit
/// there). Explicit return type (NOT `-> Self` — [M-generic-value-self-
/// return-transitive-cu-emission], №59).
///
/// Manual for-loop rebuild, NOT `@routes.clone()` (`Vec[MethodEntry]`) —
/// live codegen gap found via `nova test src`: `Vec[T].@clone()`'s
/// generated per-element clone dispatch resolved `MethodEntry`'s (no
/// `@clone()` of its own) element-clone call to `MethodRouter @clone()`
/// instead (WRONG receiver type — the only other `@clone()` in this same
/// module/file) — CC-FAIL "passing 'Nova_WriteBuffer *'/'NovaValue_
/// MethodRouter' to parameter of incompatible type 'NovaValue_MethodEntry'"
/// (the exact bogus type varies by which CU pulls this code in — always
/// SOME unrelated same-CU type, never `MethodEntry`). A plain per-element
/// `for`+`push` sidesteps `Vec.@clone()`'s per-element dispatch entirely —
/// `MethodEntry`'s two fields (`str`/`Handler`) are cheap value copies,
/// no per-element clone needed anyway.
/// `[M-vec-clone-generic-element-clone-wrong-receiver-bleed]`
fn MethodRouter @clone() -> MethodRouter {
    mut out = []MethodEntry.new()
    for e in @routes { out.push(e) }
    { routes: out, @fallback }
}

fn MethodRouter mut @add(method str, h Handler) -> @ { @routes.push(MethodEntry{method, handler: h}) }

/// Add a `GET` handler to this route's method set.
#stable(since = "0.1")
export fn MethodRouter mut @get(h Handler) -> @ { @add("GET", h) }

/// Add a `POST` handler to this route's method set.
#stable(since = "0.1")
export fn MethodRouter mut @post(h Handler) -> @ { @add("POST", h) }

/// Add a `PUT` handler to this route's method set.
#stable(since = "0.1")
export fn MethodRouter mut @put(h Handler) -> @ { @add("PUT", h) }

/// Add a `DELETE` handler to this route's method set.
#stable(since = "0.1")
export fn MethodRouter mut @delete(h Handler) -> @ { @add("DELETE", h) }

/// Add a `PATCH` handler to this route's method set.
#stable(since = "0.1")
export fn MethodRouter mut @patch(h Handler) -> @ { @add("PATCH", h) }

/// Per-route 405 override (property write) — served instead of the generic
/// `405 + Allow` wire response when the path matches but the method does not.
#stable(since = "0.1")
export fn MethodRouter mut @fallback(h Handler) -> @ { @fallback = Some(h) }

/// Per-route 405 override (property read).
#stable(since = "0.1")
export fn MethodRouter @fallback() -> Option[Handler] => @fallback

fn MethodRouter @find_handler(method str) -> Option[Handler] {
    for e in @routes {
        if e.method == method { return Some(e.handler) }
    }
    if method == "HEAD" {
        for e in @routes {
            if e.method == "GET" { return Some(e.handler) }
        }
    }
    None
}

fn MethodRouter @allowed_methods() -> []str {
    mut out = []str.new()
    for e in @routes { out.push(e.method) }
    out
}

/// Start a method-chain with a `GET` handler (`get(h).post(h2)` composability).
#stable(since = "0.1")
export fn get(h Handler) -> MethodRouter { mut mr = MethodRouter.new(); mr.get(h); mr }

/// Start a method-chain with a `POST` handler.
#stable(since = "0.1")
export fn post(h Handler) -> MethodRouter { mut mr = MethodRouter.new(); mr.post(h); mr }

/// Start a method-chain with a `PUT` handler.
#stable(since = "0.1")
export fn put(h Handler) -> MethodRouter { mut mr = MethodRouter.new(); mr.put(h); mr }

/// Start a method-chain with a `DELETE` handler.
#stable(since = "0.1")
export fn delete(h Handler) -> MethodRouter { mut mr = MethodRouter.new(); mr.delete(h); mr }

/// Start a method-chain with a `PATCH` handler.
#stable(since = "0.1")
export fn patch(h Handler) -> MethodRouter { mut mr = MethodRouter.new(); mr.patch(h); mr }

// ── RouteNode (arena element — index-based, no recursive owned pointers) ──────

// Small named edge records (same rationale as `MethodEntry` above: `(str,
// int)`/`(str, MethodRouter)` tuple-element Vecs/Options aren't exercised
// elsewhere in this package — named records use the well-trodden struct path).
type LiteralEdge  value { ro seg str, ro idx int }
type ParamEdge    value { ro name str, ro idx int }
type CatchallEdge value { ro name str, ro methods MethodRouter }

/// One trie node. `literal_children`/`param_child`/`catchall` hold child NODE
/// INDICES into the owning `Router.@nodes` arena (`catchall` is always terminal
/// — a `{*name}` segment consumes the rest of the path, so it carries the
/// `MethodRouter` directly instead of a further child index).
type RouteNode value {
    mut literal_children []LiteralEdge
    mut param_child       Option[ParamEdge]
    mut catchall          Option[CatchallEdge]
    mut methods           Option[MethodRouter]
}

fn RouteNode.new() -> RouteNode =>
    { literal_children: []LiteralEdge.new(), param_child: None, catchall: None, methods: None }

fn find_literal_child(node RouteNode, seg str) -> Option[int] {
    for e in node.literal_children {
        if e.seg == seg { return Some(e.idx) }
    }
    None
}

// ── segment helpers ────────────────────────────────────────────────────────────

fn split_segments(s str) -> []str {
    mut out = []str.new()
    for part in s.split("/") {
        if part.byte_len() > 0 { out.push(part) }
    }
    out
}

fn is_catchall_seg(seg str) -> bool => seg.starts_with("{*") && seg.ends_with("}")
fn is_param_seg(seg str) -> bool => seg.starts_with("{") && seg.ends_with("}") && !is_catchall_seg(seg)

fn extend_segs(base []str, extra str) -> []str {
    mut out = []str.new(cap: base.len() + 1)
    out.append(base)
    out.push(extra)
    out
}

// Rejoin the remaining (percent-decoded) raw path segments from `i` on — the
// captured value of a `{*name}` catch-all.
fn catchall_rest(segs []str, i int) -> str {
    consume sb = StringBuilder.new()
    mut first = true
    mut j = i
    ro n = segs.len()
    while j < n {
        if !first { sb.append("/") }
        sb.append(percent_decode(segs[j]))
        first = false
        j += 1
    }
    sb.into_str()
}

fn route_conflict_error(path str) -> HttpError =>
    HttpError.new(Other("route conflict: '${path}' conflicts with an already-registered route"))

fn validate_pattern(path str, segs []str) -> Result[(), HttpError] {
    ro n = segs.len()
    mut i = 0
    while i < n {
        if is_catchall_seg(segs[i]) && i != n - 1 {
            return Err(HttpError.new(Other("route pattern '${path}': {*...} catch-all must be the last segment")))
        }
        i += 1
    }
    Ok(())
}

fn method_not_allowed(allow []str) -> ServerResponse {
    consume sb = StringBuilder.new()
    mut first = true
    for m in allow {
        if !first { sb.append(", ") }
        sb.append(m)
        first = false
    }
    mut resp = ServerResponse.text(405, "405 method not allowed")
    resp.header("Allow", sb.into_str())
    resp
}

// ── MatchResult / CollectedRoute (small read-only value carriers) ─────────────

type MatchResult value { ro methods MethodRouter, ro params [](str, str) }
type CollectedRoute value { ro segs []str, ro methods MethodRouter }

// ── Router ─────────────────────────────────────────────────────────────────────

/// Segment-trie HTTP router (Plan 222.1, Axum-class): static segments, `{param}`,
/// `{*rest}` catch-all; precedence static > param > catch-all; `MethodRouter`
/// per-route method dispatch (405 + `Allow` when the path matches but the
/// method doesn't); `@nest` for prefix-grouped sub-routers; `@fallback` for the
/// global 404. Route registration (`@route`/`@get`/…/`@nest`) is fallible
/// (`Result[(), HttpError]`) — a duplicate/conflicting route is a typed error,
/// not a panic.
#stable(since = "0.1")
export type Router value {
    mut nodes    []RouteNode
    mut fallback Option[Handler]
    // Middleware chain (Plan 222.4, `middleware.nv`) — accumulated by
    // `@layer`, baked into handlers INSIDE `@insert_segs` at registration
    // time. NOT consulted by `@dispatch`/`@fallback` directly (see
    // `middleware.nv`'s banner for the `Router.@fallback` exemption).
    mut layers   []Middleware
}

/// Empty router (a bare root node, no routes, no fallback, no layers).
#stable(since = "0.1")
export fn Router.new() -> Router {
    mut nodes []RouteNode = []RouteNode.new()
    nodes.push(RouteNode.new())
    { nodes, fallback: None, layers: []Middleware.new() }
}

/// Global 404 handler (property write) — served when NO path in the trie
/// matches at all (distinct from `MethodRouter.@fallback`, the per-route 405
/// override below).
#stable(since = "0.1")
export fn Router mut @fallback(h Handler) -> @ { @fallback = Some(h) }

/// Global 404 handler (property read).
#stable(since = "0.1")
export fn Router @fallback() -> Option[Handler] => @fallback

/// Register `mr` (a composed `MethodRouter`, e.g. `get(h).post(h2)`) at `path`.
/// `path` segments: literal / `{name}` / `{*name}` (must be last). Conflicts
/// (exact-duplicate path, or a `{name}` clashing with a DIFFERENT existing
/// param name at the same trie slot, or two `{*...}` at the same slot) are a
/// typed `Err(HttpError)`, not a panic.
#stable(since = "0.1")
export fn Router mut @route(path str, mr MethodRouter) -> Result[(), HttpError] {
    @insert_segs(split_segments(path), path, mr)
}

fn Router mut @insert_segs(segs []str, path str, mr MethodRouter) -> Result[(), HttpError] {
    validate_pattern(path, segs)?
    // Bake the currently-accumulated `@layers` into every method-handler +
    // per-route `@fallback` of `mr` HERE — the single insertion point BOTH
    // `@route` (fresh registration) AND `@nest` (re-inserting a sub-router's
    // already-collected routes) funnel through, so both get "wrap at
    // registration" for free (middleware.nv banner). `Router.@fallback`
    // (global 404) is NOT touched — it never reaches `@insert_segs`.
    ro wrapped_mr = wrap_method_router(@layers, mr)
    mut idx = 0
    ro n = segs.len()
    mut i = 0
    while i < n {
        ro seg = segs[i]
        if is_catchall_seg(seg) {
            ro name = seg[2..seg.byte_len() - 1]
            mut node = @nodes[idx]
            match node.catchall {
                Some(_) => return Err(route_conflict_error(path))
                None    => {
                    node.catchall = Some(CatchallEdge{name, methods: wrapped_mr})
                    @nodes[idx] = node
                    return Ok(())
                }
            }
        } else if is_param_seg(seg) {
            ro name = seg[1..seg.byte_len() - 1]
            // `mut` from the start (D246 canon (a)) — this local IS mutated
            // in the `None` arm below (no separate `updated` copy needed);
            // nothing outside this scope reads `node` after `@nodes[idx] =
            // node` writes the result back.
            mut node = @nodes[idx]
            match node.param_child {
                Some(pe) => {
                    if pe.name != name { return Err(route_conflict_error(path)) }
                    idx = pe.idx
                }
                None => {
                    @nodes.push(RouteNode.new())
                    ro new_idx = @nodes.len() - 1
                    node.param_child = Some(ParamEdge{name, idx: new_idx})
                    @nodes[idx] = node
                    idx = new_idx
                }
            }
        } else {
            // Same rationale as the param-segment arm above.
            mut node = @nodes[idx]
            match find_literal_child(node, seg) {
                Some(child_idx) => { idx = child_idx }
                None => {
                    @nodes.push(RouteNode.new())
                    ro new_idx = @nodes.len() - 1
                    node.literal_children.push(LiteralEdge{seg, idx: new_idx})
                    @nodes[idx] = node
                    idx = new_idx
                }
            }
        }
        i += 1
    }
    mut node = @nodes[idx]
    match node.methods {
        Some(_) => Err(route_conflict_error(path))
        None    => {
            node.methods = Some(wrapped_mr)
            @nodes[idx] = node
            Ok(())
        }
    }
}

// NB (strict-effects package gate, 222 §9): these five sugar methods build
// the `MethodRouter` INLINE (not via the free-fn constructors `get(h)`/
// `post(h)`/… declared above) — the strict-effects capability walk checks
// callee effects against ALL same-name free-fn overloads in the CU
// (types/mod.rs `check_callee_effects`, documented false-positive corner:
// "проверяем эффекты у всех overloads"), and in any CU that also loads
// `http.client` the client's `get(url str) Http`/`post(url, body) Http`/…
// shadow-match by name → bogus E_UNDECLARED_TRANSITIVE_EFFECT `Http` here.
// Same-name-bleed defect family as [M-crossmodule-samename-typecheck-bleed];
// reported to integrator (this worktree does not touch the nova repo). The
// free-fn constructors themselves stay exported — user call-sites that never
// import `http.client` are unaffected.

/// Register a single `GET` handler at `path` (sugar over `@route(path, get(h))`).
#stable(since = "0.1")
export fn Router mut @get(path str, h Handler) -> Result[(), HttpError] {
    mut mr = MethodRouter.new(); mr.get(h); @route(path, mr)
}

/// Register a single `POST` handler at `path`.
#stable(since = "0.1")
export fn Router mut @post(path str, h Handler) -> Result[(), HttpError] {
    mut mr = MethodRouter.new(); mr.post(h); @route(path, mr)
}

/// Register a single `PUT` handler at `path`.
#stable(since = "0.1")
export fn Router mut @put(path str, h Handler) -> Result[(), HttpError] {
    mut mr = MethodRouter.new(); mr.put(h); @route(path, mr)
}

/// Register a single `DELETE` handler at `path`.
#stable(since = "0.1")
export fn Router mut @delete(path str, h Handler) -> Result[(), HttpError] {
    mut mr = MethodRouter.new(); mr.delete(h); @route(path, mr)
}

/// Register a single `PATCH` handler at `path`.
#stable(since = "0.1")
export fn Router mut @patch(path str, h Handler) -> Result[(), HttpError] {
    mut mr = MethodRouter.new(); mr.patch(h); @route(path, mr)
}

/// Merge `sub`'s route tree under `prefix` (Axum-style nesting/grouping).
/// `sub`'s own routes were already conflict-free at ITS OWN registration time;
/// `@nest` re-runs the same conflict check against `self`'s (possibly
/// non-empty) tree, so a prefix collision with an existing route in `self` is
/// still a typed `Err`, not a panic. `sub.@fallback` is NOT threaded through
/// (documented simplification, see file banner).
#stable(since = "0.1")
export fn Router mut @nest(prefix str, sub Router) -> Result[(), HttpError] {
    ro prefix_segs = split_segments(prefix)
    ro collected = sub.collect_from(0, []str.new())
    mut i = 0
    ro n = collected.len()
    while i < n {
        ro r = collected[i]
        mut full = []str.new(cap: prefix_segs.len() + r.segs.len())
        full.append(prefix_segs)
        full.append(r.segs)
        match @insert_segs(full, prefix, r.methods) {
            Ok(_)  => ()
            Err(e) => return Err(e)
        }
        i += 1
    }
    Ok(())
}

// DFS over the trie, reconstructing each registered route's segment list
// (literal / "{name}" / "{*name}") + its `MethodRouter` — used by `@nest` to
// re-insert `sub`'s routes under `prefix`.
fn Router @collect_from(idx int, prefix []str) -> []CollectedRoute {
    ro node = @nodes[idx]
    mut out = []CollectedRoute.new()
    match node.methods {
        Some(mr) => out.push(CollectedRoute{segs: prefix, methods: mr})
        None     => ()
    }
    for e in node.literal_children {
        out.append(@collect_from(e.idx, extend_segs(prefix, e.seg)))
    }
    match node.param_child {
        Some(pe) => out.append(@collect_from(pe.idx, extend_segs(prefix, "{${pe.name}}")))
        None => ()
    }
    match node.catchall {
        Some(ce) => out.push(CollectedRoute{segs: extend_segs(prefix, "{*${ce.name}}"), methods: ce.methods})
        None => ()
    }
    out
}

// Trie lookup with Axum-class precedence (literal > param > catch-all,
// backtracking on a deeper dead end) — pure read traversal, no mutation.
fn Router @match_from(idx int, segs []str, i int) -> Option[MatchResult] {
    ro node = @nodes[idx]
    if i == segs.len() {
        return match node.methods {
            Some(mr) => {
                mut ps [](str, str) = []
                Some(MatchResult{methods: mr, params: ps})
            }
            None => None
        }
    }
    ro seg = segs[i]
    for e in node.literal_children {
        if e.seg == seg {
            match @match_from(e.idx, segs, i + 1) {
                Some(m) => return Some(m)
                None    => ()
            }
        }
    }
    match node.param_child {
        Some(pe) => {
            match @match_from(pe.idx, segs, i + 1) {
                Some(m) => {
                    mut p [](str, str) = []
                    p.push((pe.name, percent_decode(seg)))
                    p.append(m.params)
                    return Some(MatchResult{methods: m.methods, params: p})
                }
                None => ()
            }
        }
        None => ()
    }
    match node.catchall {
        Some(ce) => {
            mut p [](str, str) = []
            p.push((ce.name, catchall_rest(segs, i)))
            return Some(MatchResult{methods: ce.methods, params: p})
        }
        None => ()
    }
    None
}

/// Route a request → response: 404 (`@fallback`, or a default 404 body) if NO
/// path in the trie matches; the matched `MethodRouter`'s own `@fallback` (or a
/// generic `405 + Allow`) if the path matches but the method doesn't; otherwise
/// the matched handler, with `{name}`/`{*name}` captures attached as raw
/// `ServerRequest.@params` (typed extraction is 222.3, layered on top).
#stable(since = "0.1")
// `req` param stays bare (`ro`, D176 default) — canon (a) (`mut` param) was
// tried and REJECTED: it hits a live codegen gap calling a method with an
// ordinary (non-receiver) `mut`-typed struct arg (see `ServerRequest.
// @clone()`'s own comment, server.nv, for the exact repro/CC-FAIL text and
// marker). (b) instead: `.clone()` (D230) an independent mutable copy —
// `@params(m.params)` below needs a mutable receiver, and the clone is
// scoped to this fn only.
export fn Router @dispatch(req ServerRequest) -> ServerResponse {
    mut rq = req.clone()
    ro segs = split_segments(rq.path())
    match @match_from(0, segs, 0) {
        Some(m) => {
            rq.params(m.params)
            ro reqm = rq.method().str()
            match m.methods.find_handler(reqm) {
                Some(h) => h(rq)
                None => match m.methods.fallback() {
                    Some(h) => h(rq)
                    None    => method_not_allowed(m.methods.allowed_methods())
                }
            }
        }
        None => match @fallback {
            Some(h) => h(rq)
            None    => ServerResponse.text(404, "404 page not found")
        }
    }
}

// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-http: server/ws_upgrade.nv — `WebSocketUpgrade` extractor (Plan
// 222.14 §3, СЛОЙ 2, minimal per 222 zone rules this wave). Peer of
// `extract.nv`/`server.nv` in the SAME module (`http.server`) — folder-module
// peers compile in sorted order (D78); `ws_upgrade` sorts AFTER `server` and
// `extract` (needs `ServerRequest`, `FromRequest`, both already declared).
//
// Imports `http.ws` (frame codec + handshake, СЛОЙ 1) — allowed, СЛОЙ 2 may
// depend on СЛОЙ 1. Does NOT import `http.servernet` — see the important
// limitation below.
//
// ── `@on_upgrade` — HIJACK WIRED (Plan 222 final-plumbing task 1) ──────────
// `[M-ws-on_upgrade-hijack-not-wired]`: CLOSED. `ServerResponse` gained an
// `upgrade Option[fn(TcpStream) Net -> ()]` hook field (`server.nv`, mirrors
// `background`'s `@take_background` shape) — `@on_upgrade` below sets it to a
// closure that wraps the handed-off `TcpStream` as a `WebSocket` and invokes
// `h`. `http.servernet.serve_connection` (serve.nv) checks
// `resp.take_upgrade()` AFTER writing this response's 101 bytes to the wire
// and, if set, hands the live socket to the hook INSTEAD OF the normal
// keep-alive continuation/close — see that fn's own comment for the
// consume-flow shape. Live end-to-end proof: `servernet/rt/
// ws_upgrade_hijack_smoke.nv` (HTTP upgrade request through `serve_connection`
// → echo over the real socket) — `ws/rt/socket_echo_smoke.nv` stays as the
// lower-level protocol-only proof (no `servernet` dependency, by design, see
// that file's own banner).

module http.server

import http.{HttpError}
import std.net.{TcpStream}
import http.ws.{is_upgrade_request, ws_accept_key, WebSocket}

/// Extractor: confirms `req` is a valid WebSocket upgrade request and
/// captures what the handshake needs (`Sec-WebSocket-Key` + any offered
/// subprotocols). Value type (D117) — cheap, read-only after construction.
#stable(since = "0.1")
export type WebSocketUpgrade value {
    priv key       str
    priv protocols []str
}

/// Client-offered `Sec-WebSocket-Protocol` list (RFC 6455 §11.3.4), in the
/// order offered. Plan §5 V1 boundary: no negotiation logic — `@on_upgrade`
/// just echoes the FIRST one, if any.
#stable(since = "0.1")
export fn WebSocketUpgrade @protocols() -> []str => @protocols

#impl(FromRequest)
export fn WebSocketUpgrade.from_request(req ServerRequest) -> Result[WebSocketUpgrade, HttpError] {
    if !is_upgrade_request(req) {
        return Err(HttpError.protocol_error("not a valid WebSocket upgrade request (method/Upgrade/Connection/Sec-WebSocket-Version/-Key)"))
    }
    ro key = match req.header("Sec-WebSocket-Key") {
        Some(k) => k
        None    => "" // unreachable: is_upgrade_request already required this header present
    }
    ro protocols = match req.header("Sec-WebSocket-Protocol") {
        Some(v) => split_protocol_list(v)
        None    => []str.new()
    }
    Ok(WebSocketUpgrade { key, protocols })
}

fn split_protocol_list(v str) -> []str {
    mut out []str = []str.new()
    for p in v.split(",") {
        ro t = p.trim_ascii()
        if t.byte_len() > 0 { out.push(t) }
    }
    out
}

/// Build the `101 Switching Protocols` response for this upgrade (RFC 6455
/// §4.2.2): computed `Sec-WebSocket-Accept` + optional protocol echo.
/// `protocol` is normally `@protocols().get(0)` — exposed as an explicit
/// param so a caller that DOES want to pick among several offered
/// subprotocols still can (plan §5: "только эхо выбранного, без
/// переговорной логики" — the CHOOSING is the caller's business, the
/// ECHOING is this fn's).
#stable(since = "0.1")
export fn WebSocketUpgrade @accept_response(proto Option[str]) -> ServerResponse {
    ro accept = match ws_accept_key(@key) {
        Ok(a)  => a
        Err(_) => "" // malformed key already rejected by is_upgrade_request's presence check;
                     // a still-bad key (wrong decoded length) surfaces as an accept mismatch
                     // the client will itself reject — no silent 101 lie either way.
    }
    mut resp = ServerResponse.empty(101)
    resp.header("Upgrade", "websocket")
    resp.header("Connection", "Upgrade")
    resp.header("Sec-WebSocket-Accept", accept)
    match proto {
        Some(p) => { resp.header("Sec-WebSocket-Protocol", p) }
        None    => ()
    }
    resp
}

/// Complete the handshake and wire `h` to the live socket (plan §3 exact
/// signature): once `http.servernet.serve_connection` has written this
/// response's 101 bytes, it hands the raw `TcpStream` to the hook installed
/// below, which wraps it as a `WebSocket` (default 16 MiB message limit,
/// `WebSocket.new`) and calls `h` — `h` owns the `WebSocket` from then on and
/// is responsible for `@close()`ing it (D133 must-consume), same contract as
/// `ws/rt/socket_echo_smoke.nv`'s own hand-rolled echo loop.
#stable(since = "0.1")
export fn WebSocketUpgrade consume @on_upgrade(h fn(WebSocket) Net -> ()) -> ServerResponse {
    ro proto = if @protocols.len() > 0 { Some(@protocols[0]) } else { None }
    mut resp = @accept_response(proto)
    ro hook = fn(stream TcpStream) Net -> () {
        consume ws = WebSocket.new(stream)
        h(ws)
    }
    resp.upgrade(hook)
    resp
}

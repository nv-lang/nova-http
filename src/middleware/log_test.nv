// SPDX-License-Identifier: MIT OR Apache-2.0
// Plan 222.12 Ф.2 — `http.middleware.log` pin tests. Fully deterministic:
// `with Time = th.fixed_ms(...)` freezes the duration at 0ms
// (rate_limiter_test.nv recipe), the sink is a capturing closure (no stdout
// scraping), request-ids count from this config's own fresh counter.
// Asserts stay INSIDE the with-block (closure-capture scope note,
// std/concurrency/retry_test.nv precedent).

module middleware.log_test

import http.middleware.log.{Log, logger}
import http.server.{Router, route_once, handler_fn, ServerResponse}
import std.testing.handlers as th

fn req(method str, path str, headers [](str, str)) -> []u8 {
    consume sb = StringBuilder.new()
    sb.cap(128)
    sb.append("${method} ${path} HTTP/1.1\r\nHost: x\r\n")
    for (k, v) in headers {
        sb.append("${k}: ${v}\r\n")
    }
    sb.append("\r\n")
    sb.into_str().bytes()
}

fn hdr(resp ServerResponse, name str) -> str {
    match resp.headers.get(name) {
        Some(hv) => match hv.to_str() { Ok(s) => s, Err(_) => "" }
        None     => ""
    }
}

fn routed(cfg Log) Time -> Router {
    mut r = Router.new()
    r.layer(logger(cfg))
    r.get("/x", handler_fn(|_req| ServerResponse.text(200, "ok")))!!
    r
}

test "log: line has method, path, status, size, duration; id generated" {
    mut lines []str = []
    mut cfg = Log.new()
    cfg.sink(fn(line str) -> () => { lines.push(line) })
    with Time = th.fixed_ms(0) {
        ro resp = route_once(routed(cfg), req("GET", "/x", []))
        assert(resp.status_code() == 200)
        assert(hdr(resp, "x-request-id") == "req-1")
        assert(lines.len() == 1)
        assert(lines[0] == "[req-1] GET /x -> 200 2B in 0ms")
    }
}

test "log: ids increment per request through the shared counter" {
    mut lines []str = []
    mut cfg = Log.new()
    cfg.sink(fn(line str) -> () => { lines.push(line) })
    with Time = th.fixed_ms(0) {
        ro r = routed(cfg)
        ro r1 = route_once(r, req("GET", "/x", []))
        ro r2 = route_once(r, req("GET", "/x", []))
        assert(hdr(r1, "x-request-id") == "req-1")
        assert(hdr(r2, "x-request-id") == "req-2")
        assert(lines.len() == 2)
    }
}

test "log: incoming X-Request-Id is propagated, not regenerated" {
    mut lines []str = []
    mut cfg = Log.new()
    cfg.sink(fn(line str) -> () => { lines.push(line) })
    with Time = th.fixed_ms(0) {
        ro resp = route_once(routed(cfg), req("GET", "/x", [("X-Request-Id", "abc-42")]))
        assert(hdr(resp, "x-request-id") == "abc-42")
        assert(lines[0] == "[abc-42] GET /x -> 200 2B in 0ms")
    }
}

test "log: hostile X-Request-Id (non-token) is replaced by a fresh id" {
    mut lines []str = []
    mut cfg = Log.new()
    cfg.sink(fn(line str) -> () => { lines.push(line) })
    with Time = th.fixed_ms(0) {
        ro resp = route_once(routed(cfg), req("GET", "/x", [("X-Request-Id", "two words")]))
        assert(hdr(resp, "x-request-id") == "req-1")
    }
}

test "log: request_id(false) -> no header, no [] prefix" {
    mut lines []str = []
    mut cfg = Log.new()
    cfg.sink(fn(line str) -> () => { lines.push(line) }).request_id(false)
    with Time = th.fixed_ms(0) {
        ro resp = route_once(routed(cfg), req("GET", "/x", []))
        assert(hdr(resp, "x-request-id") == "")
        assert(lines[0] == "GET /x -> 200 2B in 0ms")
    }
}

test "log: real_ip(true) appends the first X-Forwarded-For hop" {
    mut lines []str = []
    mut cfg = Log.new()
    cfg.sink(fn(line str) -> () => { lines.push(line) }).real_ip(true)
    with Time = th.fixed_ms(0) {
        ro _ = route_once(routed(cfg), req("GET", "/x", [("X-Forwarded-For", "1.2.3.4, 10.0.0.1")]))
        assert(lines[0] == "[req-1] GET /x -> 200 2B in 0ms from 1.2.3.4")
    }
}

test "log: real_ip stays silent without the header" {
    mut lines []str = []
    mut cfg = Log.new()
    cfg.sink(fn(line str) -> () => { lines.push(line) }).real_ip(true)
    with Time = th.fixed_ms(0) {
        ro _ = route_once(routed(cfg), req("GET", "/x", []))
        assert(lines[0] == "[req-1] GET /x -> 200 2B in 0ms")
    }
}

test "log: 404 fallback path is NOT logged (route_layer semantics, 222.4 pin)" {
    mut lines []str = []
    mut cfg = Log.new()
    cfg.sink(fn(line str) -> () => { lines.push(line) })
    with Time = th.fixed_ms(0) {
        ro resp = route_once(routed(cfg), req("GET", "/missing", []))
        assert(resp.status_code() == 404)
        assert(lines.len() == 0)
    }
}

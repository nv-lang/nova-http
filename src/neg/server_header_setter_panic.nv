// Plan http-props (2026-07-07) — ПОПРАВКА владельца: setter-свойства (`mut @x(v)
// -> @`) над HeaderMap — ТОТАЛЬНЫЕ (не глотают `Result`). `ServerResponse.@header`
// пишет заголовки, которые задаёт САМ обработчик (не сеть) — невалидное имя/CR-LF
// в значении = баг вызывающего → `insert(..)!!` паникует вместо тихого success.
//
// `!!` on a typed `Result[T, HttpError]` panics with the generic runtime
// diagnostic fallback ("<typed err>"), not the error's own message text.
// EXPECT_RUNTIME_PANIC <typed err>

module neg.server_header_setter_panic

import ../server.{ServerResponse}

test "ServerResponse.header() panics on CR/LF-injected value (caller bug)" {
    mut resp = ServerResponse.text(200, "ok")
    resp.header("X-Bad", "evil\r\nSet-Cookie: x=1")
}

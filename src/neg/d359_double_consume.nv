// EXPECT_COMPILE_ERROR D131
// D359: must-consume Body — двойное потребление = compile-error (use-after-consume).
module neg.d359_double_consume

import http.{Body}

test "body consumed twice → compile error" {
    consume b = "x".bytes().to_body()
    ro _ = b.into_bytes()
    ro _2 = b.into_bytes()
}

// SPDX-License-Identifier: MIT OR Apache-2.0
// Plan 182 Ф.2 (migrated from nova_tests/http_transport/transport_test.nv) —
// real_http() handler smoke test. Exercises the client → Http seam → real_http
// path (effect-over-effect: real_http performs Net).
//
// Plan 116 Ф.5.3: https больше НЕ захардгейчен на Err(Tls) — `https_send_over_net`
// делает НАСТОЯЩЕЕ TLS-рукопожатие (SNI=host, SystemRoots). Против `mock_net`
// (peer НЕ говорит TLS: read отдаёт "mock-reply") рукопожатие детерминированно
// проваливается → `HttpError{kind: Tls}`. Полный self-signed HTTPS-round-trip
// через `HttpClient` требует хука кастомных корней в клиенте (SystemRoots
// хардкожен в real_http) — followup [M-116-https-client-custom-roots]; сам
// TLS-слой покрыт std/tls loopback-тестами (handshake/cert_modes/mtls).
// Live plaintext round-trips over a real socket are *_slow.nv.

module http.transport

import ../client.{HttpClient}
import std.net.{mock_net}

test "real_http: https делает реальное TLS-рукопожатие; non-TLS peer → Err(Tls)" {
    with Net = mock_net() {
        with Http = real_http() {
            match HttpClient.new().get("https://secure.example/x").send() {
                Ok(r)  => { assert(match r.drain() { Ok(_) => true, Err(_) => false }); assert(false) }
                Err(e) => assert(match e.kind { Tls => true, _ => false })
            }
        }
    }
}

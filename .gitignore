# Codegen artifacts (mirrors monorepo's std/**/*.c convention — nova test
# writes generated .c/.exe/.obj next to source files it compiles).
src/**/*.c
src/**/*.exe
src/**/*.obj
src/**/*.pdb
src/**/*.ilk

# nova build/test scratch (obj dirs, libuv one-time build cache, lockfile
# resolution scratch under target/).
target/

# Plan 204 дофикс №2 (D420): machine-local [replace] overrides — NEVER
# commit (a committed [replace] would break a clean clone whose override
# path only exists on the author's machine; see spec/decisions/09-tooling.md
# D420 and compiler-codegen/src/manifest.rs `check_no_committed_replace`).
nova.local.toml

# Machine-local nova.exe copy (Plan 222.1 worktree convenience — main repo's
# compiler was mid-rebuild when this worktree was set up).
.tools/
